---
// src/components/Chat.astro
---

<section class="chat-section" id="chat-anchor">
  <div class="chat-header">
    <p class="chat-online"><span class="dot"></span>AI Consultant · Online</p>
    <h2>Rancang projek website anda</h2>
    <p class="chat-sub">Ceritakan tentang website yang anda inginkan.</p>
  </div>

  <div class="chat-window">
    <div class="chat-messages" id="chatMessages"></div>

    <div class="suggested-prompts">
      <button class="prompt-chip">Saya nak buat website restoran</button>
      <button class="prompt-chip">I want an online store</button>
      <button class="prompt-chip">Nak buat landing page</button>
      <button class="prompt-chip">I need a booking system</button>
      <button class="prompt-chip">Berapa kos website?</button>
    </div>

    <div class="chat-input-area">
      <textarea class="chat-input" id="chatInput" rows="1"
        placeholder="Ceritakan projek website anda..."></textarea>
      <button class="send-btn" id="sendBtn" aria-label="Hantar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"/>
          <polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<!-- Modal email — muncul selepas user taip HANTAR -->
<div class="modal-overlay" id="emailModal" hidden>
  <div class="modal">
    <button class="modal-close" id="modalClose">✕</button>
    <h3>Hantar Butiran Projek</h3>
    <p class="modal-sub">Maklumat anda akan dihantar kepada pasukan 404found.studio. Anda juga akan terima salinan email.</p>

    <label>Nama Penuh <span class="req">*</span></label>
    <input type="text"  id="emailName"  placeholder="Ahmad Razif" />
    <label>Alamat Emel <span class="req">*</span></label>
    <input type="email" id="emailFrom"  placeholder="ahmad@example.com" />
    <label>Nombor WhatsApp <span class="req">*</span></label>
    <input type="tel"   id="emailPhone" placeholder="+60123456789" />

    <div class="modal-actions">
      <button class="btn-send"   id="sendEmailBtn">Hantar Sekarang</button>
      <button class="btn-cancel" id="cancelEmailBtn">Batal</button>
    </div>
    <div id="emailStatus"></div>
  </div>
</div>

<style>
.chat-section{padding:4rem 2rem 6rem;max-width:860px;margin:0 auto}
.chat-header{text-align:center;margin-bottom:3rem}
.chat-online{font-family:'Space Mono',monospace;font-size:.72rem;color:var(--accent);letter-spacing:.15em;text-transform:uppercase;margin-bottom:.5rem;display:flex;align-items:center;justify-content:center;gap:.5rem}
.dot{width:6px;height:6px;background:var(--accent);border-radius:50%;animation:pulse 2s infinite}
.chat-header h2{font-size:2rem;font-weight:700;letter-spacing:-.02em;margin-bottom:.75rem}
.chat-sub{color:var(--text2);font-size:.95rem}

.chat-window{background:var(--bg2);border:1px solid var(--border);border-radius:16px;overflow:hidden;display:flex;flex-direction:column;height:580px}
.chat-messages{flex:1;overflow-y:auto;padding:1.5rem;display:flex;flex-direction:column;gap:1rem;scroll-behavior:smooth}
.chat-messages::-webkit-scrollbar{width:4px}
.chat-messages::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}

.msg{display:flex;gap:.75rem;animation:fadeUp .3s ease}
.msg.user{flex-direction:row-reverse}
.msg-avatar{width:32px;height:32px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.68rem;font-weight:700;font-family:'Space Mono',monospace}
.msg-avatar.ai{background:var(--accent-dim);color:var(--accent);border:1px solid rgba(0,255,136,.3)}
.msg-avatar.user{background:var(--bg4);color:var(--text2);border:1px solid var(--border)}
.msg-bubble{max-width:78%;padding:.875rem 1.125rem;border-radius:12px;font-size:.9rem;line-height:1.7}
.msg.ai .msg-bubble{background:var(--bg3);border:1px solid var(--border);border-top-left-radius:4px}
.msg.user .msg-bubble{background:var(--accent-dim);border:1px solid rgba(0,255,136,.2);border-top-right-radius:4px;text-align:right}

/* Bold text dalam bubble */
.msg-bubble strong{font-weight:700;color:var(--accent)}

/* Inline CTA buttons yang muncul selepas summary */
.cta-inline{display:flex;flex-direction:column;gap:.5rem;margin-top:1rem}
.cta-btn-inline{
  padding:.75rem 1.25rem;border-radius:10px;font-size:.9rem;cursor:pointer;
  border:2px solid;font-family:'Syne',sans-serif;font-weight:700;
  transition:all .2s;text-align:center;display:flex;align-items:center;
  justify-content:center;gap:.5rem;width:100%;
}
.cta-hantar{background:var(--accent);border-color:var(--accent);color:#000}
.cta-hantar:hover{background:var(--accent2);border-color:var(--accent2)}
.cta-wa{background:#25D366;border-color:#25D366;color:#fff}
.cta-wa:hover{background:#1da851;border-color:#1da851}

/* Typing dots */
.typing-indicator{display:flex;gap:4px;align-items:center;padding:.25rem 0}
.typing-dot{width:6px;height:6px;border-radius:50%;background:var(--accent);animation:typingBounce 1.2s infinite}
.typing-dot:nth-child(2){animation-delay:.2s}
.typing-dot:nth-child(3){animation-delay:.4s}

/* Summary card */
.summary-card{background:var(--bg3);border:1px solid rgba(0,255,136,.3);border-radius:12px;padding:1.25rem;margin-top:.75rem}
.summary-card h3{font-size:.72rem;letter-spacing:.15em;text-transform:uppercase;color:var(--accent);margin-bottom:1rem;font-family:'Space Mono',monospace}
.summary-row{display:flex;justify-content:space-between;padding:.4rem 0;border-bottom:1px solid var(--border);font-size:.83rem;gap:.5rem}
.summary-row:last-of-type{border-bottom:none}
.summary-label{color:var(--text2);font-size:.78rem;flex-shrink:0}
.summary-value{color:var(--text);font-weight:600;text-align:right}
.summary-price{color:var(--accent);font-family:'Space Mono',monospace}

/* Prompts */
.suggested-prompts{padding:.75rem 1.25rem;border-top:1px solid var(--border);display:flex;gap:.5rem;overflow-x:auto;scrollbar-width:none}
.suggested-prompts::-webkit-scrollbar{display:none}
.prompt-chip{flex-shrink:0;padding:.4rem .875rem;background:var(--bg3);border:1px solid var(--border);border-radius:20px;font-size:.78rem;color:var(--text2);cursor:pointer;transition:all .2s;white-space:nowrap;font-family:'Space Mono',monospace}
.prompt-chip:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-dim)}

/* Input */
.chat-input-area{padding:1rem 1.25rem;border-top:1px solid var(--border);display:flex;gap:.75rem;align-items:flex-end;background:var(--bg2)}
.chat-input{flex:1;background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:.75rem 1rem;color:var(--text);font-family:'Syne',sans-serif;font-size:.9rem;resize:none;min-height:44px;max-height:120px;outline:none;transition:border-color .2s;line-height:1.5}
.chat-input:focus{border-color:rgba(0,255,136,.4)}
.chat-input::placeholder{color:var(--text3)}
.send-btn{background:var(--accent);border:none;border-radius:8px;width:44px;height:44px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;flex-shrink:0;color:#000}
.send-btn:hover{background:var(--accent2);transform:scale(1.05)}
.send-btn:disabled{opacity:.4;cursor:not-allowed;transform:none}

/* Modal */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:200;display:flex;align-items:center;justify-content:center;padding:1rem}
.modal-overlay[hidden]{display:none}
.modal{background:var(--bg2);border:1px solid var(--border);border-radius:16px;width:100%;max-width:480px;padding:2rem;position:relative;animation:fadeUp .25s ease}
.modal h3{font-size:1.25rem;font-weight:700;margin-bottom:.4rem}
.modal-sub{font-size:.82rem;color:var(--text2);margin-bottom:1.5rem;line-height:1.6}
.modal label{display:block;font-size:.78rem;color:var(--text2);margin:.75rem 0 .35rem;text-transform:uppercase;letter-spacing:.06em}
.req{color:var(--accent)}
.modal input{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:.75rem 1rem;color:var(--text);font-family:'Syne',sans-serif;font-size:.9rem;outline:none;transition:border-color .2s}
.modal input:focus{border-color:rgba(0,255,136,.4)}
.modal-close{position:absolute;top:1.25rem;right:1.25rem;background:var(--bg4);border:1px solid var(--border);border-radius:50%;width:30px;height:30px;cursor:pointer;color:var(--text2);font-size:.85rem;display:flex;align-items:center;justify-content:center}
.modal-close:hover{border-color:var(--accent);color:var(--accent)}
.modal-actions{display:flex;gap:.75rem;margin-top:1.5rem}
.btn-send{flex:1;background:var(--accent);border:none;border-radius:8px;padding:.875rem;color:#000;font-family:'Syne',sans-serif;font-size:.9rem;font-weight:700;cursor:pointer;transition:all .2s}
.btn-send:hover{background:var(--accent2)}
.btn-send:disabled{opacity:.5;cursor:not-allowed}
.btn-cancel{background:transparent;border:1px solid var(--border2);border-radius:8px;padding:.875rem 1.25rem;color:var(--text);font-family:'Syne',sans-serif;font-size:.875rem;cursor:pointer;transition:all .2s}
.btn-cancel:hover{border-color:var(--accent);color:var(--accent)}
.status-msg{padding:.75rem 1rem;border-radius:8px;font-size:.85rem;text-align:center;margin-top:.75rem}
.status-ok{background:rgba(0,255,136,.1);color:var(--accent);border:1px solid rgba(0,255,136,.2)}
.status-err{background:rgba(255,80,80,.1);color:#ff5050;border:1px solid rgba(255,80,80,.2)}
</style>

<script>
// ── State ─────────────────────────────────────────────────
let history: {role:string;content:string}[] = [];
let summary: Record<string,any> | null = null;
let summaryShown = false;
let ctaShown = false;      // Pastikan CTA buttons muncul sekali sahaja
let loading = false;

// ── DOM ───────────────────────────────────────────────────
const msgsEl   = document.getElementById('chatMessages')!;
const inputEl  = document.getElementById('chatInput')  as HTMLTextAreaElement;
const sendBtn  = document.getElementById('sendBtn')    as HTMLButtonElement;
const modal    = document.getElementById('emailModal')!;
const statusEl = document.getElementById('emailStatus')!;

const scrollDown = () => { msgsEl.scrollTop = msgsEl.scrollHeight; };

// ── Render message ────────────────────────────────────────
function addMsg(role: 'ai'|'user', raw: string) {
  const wrap = document.createElement('div');
  wrap.className = `msg ${role}`;

  const av = document.createElement('div');
  av.className = `msg-avatar ${role}`;
  av.textContent = role === 'ai' ? 'AI' : 'Kamu';

  const bub = document.createElement('div');
  bub.className = 'msg-bubble';

  // Buang JSON block dari teks yang ditunjukkan
  const clean = raw.replace(/\[SUMMARY_START\][\s\S]*?\[SUMMARY_END\]/g,'').trim();
  // Render **bold** markdown
  bub.innerHTML = renderMarkdown(clean);

  wrap.appendChild(av);
  wrap.appendChild(bub);
  msgsEl.appendChild(wrap);
  scrollDown();
  return bub;
}

// Tukar **text** → <strong>text</strong>
function renderMarkdown(text: string): string {
  return text
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\n/g, '<br>');
}

// ── Typing dots ───────────────────────────────────────────
function showTyping() {
  const wrap = document.createElement('div');
  wrap.className = 'msg ai'; wrap.id = 'typingMsg';
  const av = document.createElement('div');
  av.className = 'msg-avatar ai'; av.textContent = 'AI';
  const bub = document.createElement('div');
  bub.className = 'msg-bubble';
  bub.innerHTML = `<div class="typing-indicator">
    <div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>
  </div>`;
  wrap.appendChild(av); wrap.appendChild(bub);
  msgsEl.appendChild(wrap); scrollDown();
}
const removeTyping = () => document.getElementById('typingMsg')?.remove();

// ── Summary card ──────────────────────────────────────────
function showSummaryCard(d: Record<string,any>, parentBub: HTMLElement) {
  const feats = Array.isArray(d.features) ? d.features.join(', ') : d.features;
  const rows: [string,string,boolean?][] = [
    d.clientName  ? ['Nama',    d.clientName] as [string,string]  : null!,
    d.clientPhone ? ['Telefon', d.clientPhone] as [string,string] : null!,
    d.clientEmail ? ['Emel',    d.clientEmail] as [string,string] : null!,
    ['Jenis Perniagaan', d.businessType||'N/A'],
    ['Jenis Website',    d.websiteType  ||'N/A'],
    ['Ciri-ciri',        feats          ||'N/A'],
    ['Anggaran Harga',   d.estimatedPrice    ||'TBD', true],
    ['Tempoh Masa',      d.estimatedTimeline ||'TBD'],
  ].filter(Boolean) as [string,string,boolean?][];

  const card = document.createElement('div');
  card.className = 'summary-card';
  card.innerHTML = `<h3>📋 Ringkasan Projek</h3>` +
    rows.map(([lbl,val,isPrice]) =>
      `<div class="summary-row">
        <span class="summary-label">${lbl}</span>
        <span class="summary-value${isPrice?' summary-price':''}">${val}</span>
      </div>`
    ).join('');
  parentBub.appendChild(card);
  scrollDown();
}

// ── CTA buttons — muncul selepas summary ─────────────────
function showCtaButtons(parentBub: HTMLElement) {
  if (ctaShown) return;
  ctaShown = true;

  const waMsg = encodeURIComponent(
    `Hi, saya ${summary?.clientName||''} baru berbincang dengan AI consultant 404found.studio.\n` +
    `Projek: ${summary?.websiteType||''} untuk ${summary?.businessType||''}\n` +
    `Anggaran: ${summary?.estimatedPrice||''}`
  );

  const cta = document.createElement('div');
  cta.className = 'cta-inline';
  cta.innerHTML = `
    <button class="cta-btn-inline cta-hantar" id="ctaHantar">
      ✉️ Hantar Butiran via Email
    </button>
    <a class="cta-btn-inline cta-wa"
       href="https://wa.me/601155525587?text=${waMsg}"
       target="_blank" rel="noopener">
      💬 Teruskan via WhatsApp
    </a>`;

  parentBub.appendChild(cta);
  cta.querySelector('#ctaHantar')!.addEventListener('click', openModal);
  scrollDown();
}

// ── Session ───────────────────────────────────────────────
function save() {
  try {
    sessionStorage.setItem('404_h', JSON.stringify(history));
    if (summary) sessionStorage.setItem('404_s', JSON.stringify(summary));
  } catch {}
}
function load() {
  try {
    const h = sessionStorage.getItem('404_h');
    if (h) history = JSON.parse(h);
    const s = sessionStorage.getItem('404_s');
    if (s) { summary = JSON.parse(s); summaryShown = true; ctaShown = false; }
  } catch {}
}

// ── API call ──────────────────────────────────────────────
async function fetchReply(msgs: typeof history): Promise<{reply?:string; command?:string; error?:string}> {
  const res = await fetch('/api/chat', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ messages: msgs, summary }),
  });
  return res.json();
}

// ── Send message ──────────────────────────────────────────
async function send() {
  const text = inputEl.value.trim();
  if (!text || loading) return;

  loading = true;
  sendBtn.disabled = true;
  inputEl.value = '';
  inputEl.style.height = 'auto';

  // Tunjuk mesej user (kecuali command senyap)
  const upperText = text.toUpperCase();
  const isCmd = /^(HANTAR|SEND|EMAIL|EMEL|WHATSAPP|WA|WASAP)$/.test(upperText);

  if (!isCmd) {
    addMsg('user', text);
  }

  history.push({ role: 'user', content: text });
  save();

  if (!isCmd) showTyping();

  try {
    const data = await fetchReply(history);
    if (!isCmd) removeTyping();

    // Handle command responses
    if (data.command === 'send_email') {
      openModal();
      history.push({ role: 'assistant', content: '[User requested email]' });
      save();
      loading = false; sendBtn.disabled = false;
      return;
    }
    if (data.command === 'whatsapp') {
      const waMsg = encodeURIComponent(
        `Hi, saya ${summary?.clientName||'pelanggan'} baru berbincang dengan AI consultant 404found.studio.\n` +
        `Projek: ${summary?.websiteType||''} untuk ${summary?.businessType||''}\n` +
        `Anggaran: ${summary?.estimatedPrice||''}`
      );
      window.open(`https://wa.me/601155525587?text=${waMsg}`, '_blank');
      history.push({ role: 'assistant', content: '[User requested WhatsApp]' });
      save();
      loading = false; sendBtn.disabled = false;
      return;
    }

    if (data.error) {
      addMsg('ai', 'Maaf, ada masalah. Cuba lagi atau hubungi kami di ' +
        "<a href='https://wa.me/601155525587' style='color:var(--accent)'>WhatsApp</a>.");
      loading = false; sendBtn.disabled = false;
      return;
    }

    const reply = data.reply ?? '';
    history.push({ role: 'assistant', content: reply });
    save();

    // Parse summary dari reply
    const m = reply.match(/\[SUMMARY_START\]([\s\S]*?)\[SUMMARY_END\]/);
    let parsedSummary: Record<string,any> | null = null;
    if (m && !summaryShown) {
      try { parsedSummary = JSON.parse(m[1].trim()); } catch {}
    }

    const bub = addMsg('ai', reply);

    // Tunjuk summary card
    if (parsedSummary && !summaryShown) {
      summaryShown = true;
      summary = parsedSummary;
      sessionStorage.setItem('404_s', JSON.stringify(summary));
      prefillModal(parsedSummary);
      showSummaryCard(parsedSummary, bub);
      // CTA buttons juga ditunjukkan
      showCtaButtons(bub);
    }

  } catch (err: any) {
    if (!isCmd) removeTyping();
    addMsg('ai', 'Maaf, ada masalah sambungan. ' +
      "<a href='https://wa.me/601155525587' style='color:var(--accent)'>Hubungi kami di WhatsApp</a>.");
  }

  loading = false;
  sendBtn.disabled = false;
}

// ── Init ──────────────────────────────────────────────────
async function init() {
  load();

  if (history.length > 0) {
    history.forEach(m => {
      if (!m.content.startsWith('__') && !m.content.startsWith('[User req')) {
        addMsg(m.role === 'user' ? 'user' : 'ai', m.content);
      }
    });
    if (summary) {
      const lastBub = msgsEl.querySelector<HTMLElement>('.msg.ai:last-child .msg-bubble');
      if (lastBub && !lastBub.querySelector('.summary-card')) {
        showSummaryCard(summary, lastBub);
        showCtaButtons(lastBub);
        prefillModal(summary);
      }
    }
    return;
  }

  showTyping();
  try {
    const data = await fetchReply([{ role: 'user', content: '__GREETING__' }]);
    removeTyping();
    const greeting = data.reply ?? 'Hai! Saya ejen AI 404found.studio. Apakah jenis website yang anda ingin bina?';
    addMsg('ai', greeting);
    history.push({ role: 'user', content: '__GREETING__' });
    history.push({ role: 'assistant', content: greeting });
    save();
  } catch {
    removeTyping();
    addMsg('ai', 'Hai! Saya ejen AI 404found.studio 👋\n\nApakah jenis website yang anda ingin bina?');
  }
}

// ── Modal ─────────────────────────────────────────────────
function prefillModal(d: Record<string,any>) {
  if (d.clientName)  (document.getElementById('emailName')  as HTMLInputElement).value = d.clientName;
  if (d.clientEmail) (document.getElementById('emailFrom')  as HTMLInputElement).value = d.clientEmail;
  if (d.clientPhone) (document.getElementById('emailPhone') as HTMLInputElement).value = d.clientPhone;
}

function openModal() {
  statusEl.innerHTML = '';
  modal.removeAttribute('hidden');
}
function closeModal() { modal.setAttribute('hidden',''); }

async function submitEmail() {
  const name  = (document.getElementById('emailName')  as HTMLInputElement).value.trim();
  const email = (document.getElementById('emailFrom')  as HTMLInputElement).value.trim();
  const phone = (document.getElementById('emailPhone') as HTMLInputElement).value.trim();
  const btn   = document.getElementById('sendEmailBtn') as HTMLButtonElement;

  if (!name || !email || !phone) {
    statusEl.innerHTML = '<div class="status-msg status-err">Sila isi nama, emel dan nombor telefon.</div>';
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Menghantar...';

  try {
    const res = await fetch('/api/email', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, fromEmail: email, phone, summary, conversation: history }),
    });
    const data = await res.json() as any;

    if (res.ok) {
      statusEl.innerHTML = `<div class="status-msg status-ok">
        ✓ Berjaya! Semak inbox anda — kami dah hantar ringkasan projek ke emel anda.
        Kami akan hubungi anda dalam masa 24 jam. 🙌
        ${data.mode==='console' ? '<br><small style="opacity:.6">(Dev: semak terminal)</small>' : ''}
      </div>`;
      btn.textContent = '✓ Dihantar';
    } else {
      throw new Error(data.error ?? 'Gagal');
    }
  } catch (e: any) {
    statusEl.innerHTML = `<div class="status-msg status-err">
      ${e.message||'Gagal hantar.'}<br>
      Cuba WhatsApp: <a href="https://wa.me/601155525587" style="color:var(--accent)">+601155525587</a>
    </div>`;
    btn.disabled = false;
    btn.textContent = 'Hantar Sekarang';
  }
}

// ── Events ────────────────────────────────────────────────
sendBtn.addEventListener('click', send);
inputEl.addEventListener('keydown', (e: KeyboardEvent) => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
});
inputEl.addEventListener('input', () => {
  inputEl.style.height = 'auto';
  inputEl.style.height = Math.min(inputEl.scrollHeight, 120) + 'px';
});
document.querySelectorAll('.prompt-chip').forEach(c =>
  c.addEventListener('click', () => { inputEl.value = c.textContent!; send(); })
);
document.getElementById('modalClose')!.addEventListener('click', closeModal);
document.getElementById('cancelEmailBtn')!.addEventListener('click', closeModal);
document.getElementById('sendEmailBtn')!.addEventListener('click', submitEmail);
modal.addEventListener('click', (e: MouseEvent) => { if (e.target===modal) closeModal(); });

init();
</script>
