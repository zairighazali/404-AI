---
// src/components/Chat.astro
---

<section class="chat-section" id="chat-anchor">
  <div class="chat-header">
    <p class="chat-online">
      <span class="dot"></span>
      AI Consultant · Online
    </p>
    <h2>Rancang projek website anda</h2>
    <p class="chat-sub">Ceritakan tentang website yang anda inginkan. AI kami akan bantu merancang projek anda langkah demi langkah.</p>
  </div>

  <div class="chat-window">
    <div class="chat-messages" id="chatMessages"></div>

    <div class="suggested-prompts">
      <button class="prompt-chip">Saya nak buat website restoran</button>
      <button class="prompt-chip">I want an online store</button>
      <button class="prompt-chip">Nak buat landing page perniagaan</button>
      <button class="prompt-chip">I need a booking system</button>
      <button class="prompt-chip">Berapa kos website?</button>
      <button class="prompt-chip">I run a service business</button>
    </div>

    <div class="chat-input-area">
      <textarea class="chat-input" id="chatInput" rows="1"
        placeholder="Ceritakan projek website anda..."></textarea>
      <button class="send-btn" id="sendBtn" aria-label="Hantar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"/>
          <polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<!-- Modal Email -->
<div class="modal-overlay" id="emailModal" hidden>
  <div class="modal">
    <button class="modal-close" id="modalClose">✕</button>
    <h3>Hantar Butiran Projek</h3>
    <p class="modal-sub">Maklumat anda akan dihantar terus ke pasukan 404found.studio.</p>

    <label>Nama Penuh <span class="req">*</span></label>
    <input type="text" id="emailName" placeholder="Ahmad Razif" />

    <label>Alamat Emel <span class="req">*</span></label>
    <input type="email" id="emailFrom" placeholder="ahmad@example.com" />

    <label>Nombor WhatsApp <span class="req">*</span></label>
    <input type="tel" id="emailPhone" placeholder="+60123456789" />

    <label>Mesej Tambahan (pilihan)</label>
    <textarea id="emailMsg" rows="3" placeholder="Sebarang maklumat tambahan..."></textarea>

    <details class="summary-toggle">
      <summary>Lihat ringkasan projek yang akan dihantar</summary>
      <textarea id="emailSummary" rows="8" class="summary-preview" readonly></textarea>
    </details>

    <div class="modal-actions">
      <button class="btn-send" id="sendEmailBtn">Hantar Emel</button>
      <button class="btn-cancel" id="cancelEmailBtn">Batal</button>
    </div>
    <div id="emailStatus"></div>
  </div>
</div>

<style>
.chat-section {
  padding: 4rem 2rem 6rem;
  max-width: 860px;
  margin: 0 auto;
}
.chat-header { text-align: center; margin-bottom: 3rem; }
.chat-online {
  font-family: 'Space Mono', monospace;
  font-size: 0.72rem;
  color: var(--accent);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 0.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
}
.dot {
  width: 6px; height: 6px;
  background: var(--accent);
  border-radius: 50%;
  animation: pulse 2s infinite;
}
.chat-header h2 { font-size: 2rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 0.75rem; }
.chat-sub { color: var(--text2); font-size: 0.95rem; line-height: 1.6; }

.chat-window {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  height: 580px;
}
.chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  scroll-behavior: smooth;
}
.chat-messages::-webkit-scrollbar { width: 4px; }
.chat-messages::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

/* Messages */
.msg { display: flex; gap: 0.75rem; animation: fadeUp 0.3s ease; }
.msg.user { flex-direction: row-reverse; }
.msg-avatar {
  width: 32px; height: 32px;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.68rem;
  font-weight: 700;
  font-family: 'Space Mono', monospace;
}
.msg-avatar.ai { background: var(--accent-dim); color: var(--accent); border: 1px solid rgba(0,255,136,0.3); }
.msg-avatar.user { background: var(--bg4); color: var(--text2); border: 1px solid var(--border); }
.msg-bubble {
  max-width: 78%;
  padding: 0.875rem 1.125rem;
  border-radius: 12px;
  font-size: 0.9rem;
  line-height: 1.65;
}
.msg.ai .msg-bubble { background: var(--bg3); border: 1px solid var(--border); border-top-left-radius: 4px; }
.msg.user .msg-bubble { background: var(--accent-dim); border: 1px solid rgba(0,255,136,0.2); border-top-right-radius: 4px; text-align: right; }

/* Typing */
.typing-indicator { display: flex; gap: 4px; align-items: center; padding: 0.25rem 0; }
.typing-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); animation: typingBounce 1.2s infinite; }
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

/* Summary card */
.summary-card {
  background: var(--bg3);
  border: 1px solid rgba(0,255,136,0.3);
  border-radius: 12px;
  padding: 1.25rem;
  margin-top: 0.75rem;
  text-align: left;
  min-width: 260px;
}
.summary-card h3 {
  font-size: 0.72rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 1rem;
  font-family: 'Space Mono', monospace;
}
.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 0.4rem 0;
  border-bottom: 1px solid var(--border);
  font-size: 0.83rem;
  gap: 0.5rem;
}
.summary-row:last-of-type { border-bottom: none; }
.summary-label { color: var(--text2); font-size: 0.78rem; flex-shrink: 0; }
.summary-value { color: var(--text); font-weight: 600; text-align: right; }
.summary-price { color: var(--accent); font-family: 'Space Mono', monospace; font-size: 0.95rem; }
.summary-contact { color: var(--accent); font-size: 0.78rem; margin-top: 0.5rem; }

.cta-buttons { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1rem; }
.cta-btn {
  padding: 0.625rem 1rem;
  border-radius: 8px;
  font-size: 0.82rem;
  cursor: pointer;
  border: none;
  font-family: 'Syne', sans-serif;
  font-weight: 600;
  transition: all 0.2s;
  text-align: center;
  display: block;
  width: 100%;
  text-decoration: none;
}
.cta-start { background: var(--accent); color: #000; }
.cta-start:hover { background: var(--accent2); }
.cta-email { background: var(--bg4); border: 1px solid var(--border2); color: var(--text); }
.cta-email:hover { border-color: var(--accent); color: var(--accent); }
.cta-wa { background: #25D366; color: #fff; }
.cta-wa:hover { background: #1da851; }

/* Prompts */
.suggested-prompts {
  padding: 0.75rem 1.25rem;
  border-top: 1px solid var(--border);
  display: flex;
  gap: 0.5rem;
  overflow-x: auto;
  scrollbar-width: none;
}
.suggested-prompts::-webkit-scrollbar { display: none; }
.prompt-chip {
  flex-shrink: 0;
  padding: 0.4rem 0.875rem;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 20px;
  font-size: 0.78rem;
  color: var(--text2);
  cursor: pointer;
  transition: all 0.2s;
  white-space: nowrap;
  font-family: 'Space Mono', monospace;
}
.prompt-chip:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }

/* Input */
.chat-input-area {
  padding: 1rem 1.25rem;
  border-top: 1px solid var(--border);
  display: flex;
  gap: 0.75rem;
  align-items: flex-end;
  background: var(--bg2);
}
.chat-input {
  flex: 1;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 0.75rem 1rem;
  color: var(--text);
  font-family: 'Syne', sans-serif;
  font-size: 0.9rem;
  resize: none;
  min-height: 44px;
  max-height: 120px;
  outline: none;
  transition: border-color 0.2s;
  line-height: 1.5;
}
.chat-input:focus { border-color: rgba(0,255,136,0.4); }
.chat-input::placeholder { color: var(--text3); }
.send-btn {
  background: var(--accent);
  border: none;
  border-radius: 8px;
  width: 44px; height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s;
  flex-shrink: 0;
  color: #000;
}
.send-btn:hover { background: var(--accent2); transform: scale(1.05); }
.send-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

/* Modal */
.modal-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.75);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1rem;
}
.modal-overlay[hidden] { display: none; }
.modal {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 16px;
  width: 100%;
  max-width: 520px;
  max-height: 90vh;
  overflow-y: auto;
  padding: 2rem;
  position: relative;
  animation: fadeUp 0.25s ease;
}
.modal h3 { font-size: 1.25rem; font-weight: 700; margin-bottom: 0.4rem; }
.modal-sub { font-size: 0.82rem; color: var(--text2); margin-bottom: 1.5rem; }
.modal label {
  display: block;
  font-size: 0.78rem;
  color: var(--text2);
  margin-bottom: 0.35rem;
  margin-top: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.req { color: var(--accent); }
.modal input, .modal textarea {
  width: 100%;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 0.7rem 1rem;
  color: var(--text);
  font-family: 'Syne', sans-serif;
  font-size: 0.875rem;
  outline: none;
  transition: border-color 0.2s;
}
.modal input:focus, .modal textarea:focus { border-color: rgba(0,255,136,0.4); }
.modal textarea { resize: vertical; line-height: 1.6; margin-bottom: 0; }
.summary-toggle {
  margin-top: 1rem;
  font-size: 0.82rem;
  color: var(--text3);
  cursor: pointer;
}
.summary-toggle summary { cursor: pointer; padding: 0.5rem 0; }
.summary-preview {
  font-family: 'Space Mono', monospace !important;
  font-size: 0.72rem !important;
  opacity: 0.6;
  margin-top: 0.5rem;
  min-height: 120px;
}
.modal-close {
  position: absolute; top: 1.25rem; right: 1.25rem;
  background: var(--bg4); border: 1px solid var(--border);
  border-radius: 50%; width: 30px; height: 30px;
  cursor: pointer; color: var(--text2); font-size: 0.85rem;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.2s;
}
.modal-close:hover { border-color: var(--accent); color: var(--accent); }
.modal-actions { display: flex; gap: 0.75rem; margin-top: 1.25rem; }
.btn-send {
  flex: 1;
  background: var(--accent); border: none;
  border-radius: 8px; padding: 0.75rem;
  color: #000; font-family: 'Syne', sans-serif;
  font-size: 0.875rem; font-weight: 700;
  cursor: pointer; transition: all 0.2s;
}
.btn-send:hover { background: var(--accent2); }
.btn-send:disabled { opacity: 0.5; cursor: not-allowed; }
.btn-cancel {
  background: transparent; border: 1px solid var(--border2);
  border-radius: 8px; padding: 0.75rem 1.25rem;
  color: var(--text); font-family: 'Syne', sans-serif;
  font-size: 0.875rem; cursor: pointer; transition: all 0.2s;
}
.btn-cancel:hover { border-color: var(--accent); color: var(--accent); }
.status-msg {
  padding: 0.75rem 1rem; border-radius: 8px;
  font-size: 0.85rem; text-align: center; margin-top: 0.75rem;
}
.status-ok { background: rgba(0,255,136,0.1); color: var(--accent); border: 1px solid rgba(0,255,136,0.2); }
.status-err { background: rgba(255,80,80,0.1); color: #ff5050; border: 1px solid rgba(255,80,80,0.2); }
</style>

<script>
// ── State ─────────────────────────────────────────────────────────────────
let history: {role: string; content: string}[] = [];
let summary: Record<string, any> | null = null;
let summaryShown = false;
let loading = false;

// ── DOM ───────────────────────────────────────────────────────────────────
const msgs     = document.getElementById('chatMessages')!;
const input    = document.getElementById('chatInput') as HTMLTextAreaElement;
const sendBtn  = document.getElementById('sendBtn') as HTMLButtonElement;
const modal    = document.getElementById('emailModal')!;
const statusEl = document.getElementById('emailStatus')!;

const scrollDown = () => { msgs.scrollTop = msgs.scrollHeight; };

// ── Render message bubble ─────────────────────────────────────────────────
function addMsg(role: 'ai'|'user', content: string, sum?: Record<string,any>|null) {
  const wrap = document.createElement('div');
  wrap.className = `msg ${role}`;

  const av = document.createElement('div');
  av.className = `msg-avatar ${role}`;
  av.textContent = role === 'ai' ? 'AI' : 'Kamu';

  const bub = document.createElement('div');
  bub.className = 'msg-bubble';
  const clean = content.replace(/\[SUMMARY_START\][\s\S]*?\[SUMMARY_END\]/g, '').trim();
  bub.innerHTML = clean.replace(/\n/g, '<br>');

  wrap.appendChild(av);
  wrap.appendChild(bub);
  msgs.appendChild(wrap);

  if (sum && !summaryShown) {
    summaryShown = true;
    summary = sum;
    bub.appendChild(makeSummaryCard(sum));
  }

  scrollDown();
  return bub;
}

// ── Streaming bubble placeholder ──────────────────────────────────────────
function streamBubble() {
  const wrap = document.createElement('div');
  wrap.className = 'msg ai';
  wrap.id = 'streamBubble';
  const av = document.createElement('div');
  av.className = 'msg-avatar ai';
  av.textContent = 'AI';
  const bub = document.createElement('div');
  bub.className = 'msg-bubble';
  bub.innerHTML = `<div class="typing-indicator">
    <div class="typing-dot"></div>
    <div class="typing-dot"></div>
    <div class="typing-dot"></div>
  </div>`;
  wrap.appendChild(av);
  wrap.appendChild(bub);
  msgs.appendChild(wrap);
  scrollDown();
  return bub;
}

// ── Summary card ──────────────────────────────────────────────────────────
function makeSummaryCard(d: Record<string, any>) {
  const feats = Array.isArray(d.features) ? d.features.join(', ') : d.features;
  const waText = encodeURIComponent(
    `Hi, saya baru berbincang tentang projek website dengan AI consultant 404found.studio.\n` +
    `Nama: ${d.clientName || ''}\n` +
    `Projek: ${d.websiteType || ''} untuk ${d.businessType || ''}\n` +
    `Anggaran: ${d.estimatedPrice || ''}`
  );

  const card = document.createElement('div');
  card.className = 'summary-card';

  // Bina rows
  const rows = [
    d.clientName  ? ['Nama Klien', d.clientName]                       : null,
    d.clientPhone ? ['Telefon',    d.clientPhone]                      : null,
    d.clientEmail ? ['Emel',       d.clientEmail]                      : null,
    ['Jenis Perniagaan', d.businessType || 'N/A'],
    ['Jenis Website',    d.websiteType  || 'N/A'],
    ['Ciri-ciri',        feats          || 'N/A'],
    ['Anggaran Harga',   d.estimatedPrice || 'TBD', true],
    ['Tempoh Masa',      d.estimatedTimeline || 'TBD'],
  ].filter(Boolean) as [string, string, boolean?][];

  card.innerHTML = `
    <h3>📋 Ringkasan Projek</h3>
    ${rows.map(([lbl, val, isPrice]) =>
      `<div class="summary-row">
        <span class="summary-label">${lbl}</span>
        <span class="summary-value ${isPrice ? 'summary-price' : ''}">${val}</span>
      </div>`
    ).join('')}
    <div class="cta-buttons">
      <a class="cta-btn cta-start" href="/contact">🚀 Mulakan Projek</a>
      <button class="cta-btn cta-email" id="openEmailBtn">✉️ Hantar Butiran via Emel</button>
      <a class="cta-btn cta-wa" href="https://wa.me/601155525587?text=${waText}"
         target="_blank" rel="noopener">💬 Chat di WhatsApp</a>
    </div>`;

  card.querySelector('#openEmailBtn')!.addEventListener('click', openModal);
  return card;
}

// ── Session storage ───────────────────────────────────────────────────────
function save() {
  try {
    sessionStorage.setItem('404_h', JSON.stringify(history));
    if (summary) sessionStorage.setItem('404_s', JSON.stringify(summary));
  } catch {}
}

function load() {
  try {
    const h = sessionStorage.getItem('404_h');
    if (h) history = JSON.parse(h);
    const s = sessionStorage.getItem('404_s');
    if (s) summary = JSON.parse(s);
  } catch {}
}

// ── Stream dari /api/chat ─────────────────────────────────────────────────
async function stream(userMsg: string): Promise<string> {
  const bub = streamBubble();
  let full = '';
  let ready = false;

  const res = await fetch('/api/chat', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ messages: history }),
  });

  if (!res.ok) throw new Error('HTTP ' + res.status);

  const reader = res.body!.getReader();
  const dec = new TextDecoder();

  while (true) {
    const { done, value } = await reader.read();
    if (done) break;
    const chunk = dec.decode(value, { stream: true });
    for (const line of chunk.split('\n')) {
      if (!line.startsWith('data: ')) continue;
      const raw = line.slice(6).trim();
      if (!raw || raw === '[DONE]') continue;
      try {
        const token = JSON.parse(raw)?.response ?? '';
        if (!token) continue;
        if (!ready) { bub.innerHTML = ''; ready = true; }
        full += token;
        const clean = full.replace(/\[SUMMARY_START\][\s\S]*?\[SUMMARY_END\]/g, '').trim();
        bub.innerHTML = clean.replace(/\n/g, '<br>');
        scrollDown();
      } catch {}
    }
  }

  // Parse summary JSON jika ada
  const m = full.match(/\[SUMMARY_START\]([\s\S]*?)\[SUMMARY_END\]/);
  if (m && !summaryShown) {
    try {
      const s = JSON.parse(m[1].trim());
      summaryShown = true;
      summary = s;
      bub.appendChild(makeSummaryCard(s));

      // Pre-fill modal dengan maklumat dari summary
      if (s.clientName)  (document.getElementById('emailName')  as HTMLInputElement).value = s.clientName;
      if (s.clientEmail) (document.getElementById('emailFrom')  as HTMLInputElement).value = s.clientEmail;
      if (s.clientPhone) (document.getElementById('emailPhone') as HTMLInputElement).value = s.clientPhone;

      scrollDown();
    } catch {}
  }

  return full;
}

// ── Send message ──────────────────────────────────────────────────────────
async function send() {
  const text = input.value.trim();
  if (!text || loading) return;

  loading = true;
  sendBtn.disabled = true;
  input.value = '';
  input.style.height = 'auto';

  addMsg('user', text);
  history.push({ role: 'user', content: text });
  save();

  try {
    const reply = await stream(text);
    history.push({ role: 'assistant', content: reply });
    save();
  } catch (e) {
    document.getElementById('streamBubble')!.querySelector('.msg-bubble')!.innerHTML =
      "Maaf, ada masalah sambungan. Cuba lagi atau hubungi kami di " +
      "<a href='https://wa.me/601155525587' style='color:var(--accent)'>WhatsApp</a>.";
  }

  loading = false;
  sendBtn.disabled = false;
}

// ── Init ──────────────────────────────────────────────────────────────────
async function init() {
  load();

  if (history.length > 0) {
    history.forEach(m => addMsg(m.role === 'user' ? 'user' : 'ai', m.content));
    if (summary) {
      const last = msgs.querySelector<HTMLElement>('.msg.ai:last-child .msg-bubble');
      if (last && !last.querySelector('.summary-card')) last.appendChild(makeSummaryCard(summary));
    }
    return;
  }

  // Greeting pertama dari AI
  const bub = streamBubble();
  let full = '';
  let ready = false;

  try {
    const res = await fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ messages: [{ role: 'user', content: '__GREETING__' }] }),
    });

    const reader = res.body!.getReader();
    const dec = new TextDecoder();
    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      for (const line of dec.decode(value, { stream: true }).split('\n')) {
        if (!line.startsWith('data: ')) continue;
        const raw = line.slice(6).trim();
        if (!raw || raw === '[DONE]') continue;
        try {
          const token = JSON.parse(raw)?.response ?? '';
          if (!token) continue;
          if (!ready) { bub.innerHTML = ''; ready = true; }
          full += token;
          bub.innerHTML = full.replace(/\n/g, '<br>');
          scrollDown();
        } catch {}
      }
    }

    history.push({ role: 'user', content: '__GREETING__' });
    history.push({ role: 'assistant', content: full });
    save();
  } catch {
    bub.innerHTML = "Hai! Saya ejen AI 404found.studio 👋<br><br>" +
      "Saya sedia membantu anda merancang projek website. " +
      "Apakah jenis website yang anda ingin bina?";
  }
}

// ── Modal ─────────────────────────────────────────────────────────────────
function openModal() {
  const s = summary || {};
  const feats = Array.isArray(s.features) ? s.features.join(', ') : (s.features || 'N/A');

  const txt = [
    'RINGKASAN PROJEK',
    '================',
    `Nama:             ${s.clientName  || 'N/A'}`,
    `Telefon:          ${s.clientPhone || 'N/A'}`,
    `Emel:             ${s.clientEmail || 'N/A'}`,
    `Jenis Perniagaan: ${s.businessType || 'N/A'}`,
    `Jenis Website:    ${s.websiteType  || 'N/A'}`,
    `Ciri-ciri:        ${feats}`,
    `Anggaran Harga:   ${s.estimatedPrice || 'N/A'}`,
    `Tempoh Masa:      ${s.estimatedTimeline || 'N/A'}`,
    '',
    'PERBUALAN:',
    ...history
      .filter(m => !m.content.startsWith('__'))
      .map(m => `[${m.role === 'user' ? 'Klien' : 'AI'}] ${m.content.replace(/\[SUMMARY_START\][\s\S]*?\[SUMMARY_END\]/g,'').trim()}`),
  ].join('\n');

  (document.getElementById('emailSummary') as HTMLTextAreaElement).value = txt;
  statusEl.innerHTML = '';
  modal.removeAttribute('hidden');
}

function closeModal() { modal.setAttribute('hidden', ''); }

async function submitEmail() {
  const name  = (document.getElementById('emailName')  as HTMLInputElement).value.trim();
  const email = (document.getElementById('emailFrom')  as HTMLInputElement).value.trim();
  const phone = (document.getElementById('emailPhone') as HTMLInputElement).value.trim();
  const msg   = (document.getElementById('emailMsg')   as HTMLTextAreaElement).value.trim();
  const btn   = document.getElementById('sendEmailBtn') as HTMLButtonElement;

  if (!name || !email || !phone) {
    statusEl.innerHTML = '<div class="status-msg status-err">Sila isi nama, emel dan nombor telefon.</div>';
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Menghantar...';

  try {
    const res = await fetch('/api/email', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name, fromEmail: email, phone, message: msg,
        summary, conversation: history,
      }),
    });

    const data = await res.json();

    if (res.ok) {
      statusEl.innerHTML = `<div class="status-msg status-ok">
        ✓ Berjaya dihantar! Kami akan hubungi anda dalam masa 24 jam.
        ${data.mode === 'console' ? '<br><small>(localhost: lihat terminal untuk output)</small>' : ''}
      </div>`;
      btn.textContent = 'Dihantar ✓';
    } else {
      throw new Error(data.error || 'Gagal');
    }
  } catch (e: any) {
    statusEl.innerHTML = `<div class="status-msg status-err">
      Gagal hantar. Hubungi terus: <a href="mailto:hello@404found.studio" style="color:var(--accent)">hello@404found.studio</a>
    </div>`;
    btn.disabled = false;
    btn.textContent = 'Hantar Emel';
  }
}

// ── Event listeners ───────────────────────────────────────────────────────
sendBtn.addEventListener('click', send);
input.addEventListener('keydown', (e: KeyboardEvent) => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
});
input.addEventListener('input', () => {
  input.style.height = 'auto';
  input.style.height = Math.min(input.scrollHeight, 120) + 'px';
});
document.querySelectorAll('.prompt-chip').forEach(c =>
  c.addEventListener('click', () => { input.value = c.textContent!; send(); })
);
document.getElementById('modalClose')!.addEventListener('click', closeModal);
document.getElementById('cancelEmailBtn')!.addEventListener('click', closeModal);
document.getElementById('sendEmailBtn')!.addEventListener('click', submitEmail);
modal.addEventListener('click', (e: MouseEvent) => { if (e.target === modal) closeModal(); });

init();
</script>
