---
// src/components/Footer.astro
---

<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <a class="logo" href="/">404<span>found</span>.studio</a>
      <p>Building fast, modern websites for Malaysian businesses. From landing pages to custom systems.</p>
    </div>

    <div class="footer-col">
      <h4>Services</h4>
      <a href="/services">Business Website</a>
      <a href="/services">Landing Page</a>
      <a href="/services">E-commerce</a>
      <a href="/services">Speed Optimisation</a>
      <a href="/services">Automation</a>
    </div>

    <div class="footer-col">
      <h4>Company</h4>
      <a href="/about">About</a>
      <a href="/pricing">Pricing</a>
      <a href="/blog">Blog</a>
      <a href="/contact">Contact</a>
    </div>

    <div class="footer-col">
      <h4>Blog</h4>
      <a href="/blog/how-much-does-a-website-cost-malaysia">Website Cost Guide</a>
      <a href="/blog/types-of-business-websites">Types of Websites</a>
      <a href="/blog/perlukah-setiap-bisnes-ada-website">Perlukah Setiap Bisnes Ada Website?</a>
      <a href="/blog/how-long-to-build-a-website">Build Timeline</a>
    </div>

    <div class="footer-col">
      <h4>Contact</h4>
      <a href="mailto:mohdzairighazali@yahoo.com">hello@404found.studio</a>
      <a href="https://wa.me/601155525587" target="_blank" rel="noopener">WhatsApp</a>
    </div>
  </div>

  <div class="footer-bottom">
    <span>© 2026 404found.studio · Malaysia</span>
    <span>Built with lovely coffee ⚡</span>
  </div>
</footer>

<style>
  footer {
    background: var(--bg2);
    border-top: 1px solid var(--border);
    padding: 3rem 2rem;
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr repeat(4, 1fr);
    gap: 3rem;
  }

  .logo {
    font-family: 'Space Mono', monospace;
    font-size: 1rem;
    color: var(--accent);
    display: block;
    margin-bottom: 0.75rem;
  }

  .logo span { color: var(--text2); }

  .footer-brand p {
    font-size: 0.82rem;
    color: var(--text2);
    line-height: 1.7;
    max-width: 260px;
  }

  .footer-col h4 {
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text3);
    margin-bottom: 1rem;
    font-family: 'Space Mono', monospace;
  }

  .footer-col a {
    display: block;
    font-size: 0.85rem;
    color: var(--text2);
    margin-bottom: 0.5rem;
    transition: color 0.2s;
  }

  .footer-col a:hover { color: var(--accent); }

  .footer-bottom {
    max-width: 1100px;
    margin: 2rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.78rem;
    color: var(--text3);
    font-family: 'Space Mono', monospace;
  }

  @media (max-width: 768px) {
    .footer-inner { grid-template-columns: 1fr 1fr; }
  }
</style>
