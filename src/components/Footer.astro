---
// src/components/Footer.astro
---

<footer>
  <div class="footer-top">
    <div class="footer-brand">
      <a class="logo" href="/">
        <span class="logo-404">404</span>found.studio
      </a>
      <p>Bina website untuk bisnes Malaysia.<br />Dari landing page sampai custom system.</p>
      <div class="footer-contact-inline">
        <a href="mailto:hello@404found.studio">hello@404found.studio</a>
        <span>·</span>
        <a href="https://wa.me/601155525587" target="_blank" rel="noopener">WhatsApp</a>
      </div>
    </div>

    <div class="footer-cols">
      <div class="footer-col">
        <h4>Services</h4>
        <a href="/services">Business Website</a>
        <a href="/services">Landing Page</a>
        <a href="/services">E-commerce</a>
        <a href="/services">Custom System</a>
        <a href="/services">Speed Optimisation</a>
      </div>

      <div class="footer-col">
        <h4>Company</h4>
        <a href="/studio">Studio</a>
        <a href="/pricing">Pricing</a>
        <a href="/blog">Blog</a>
        <a href="/contact">Contact</a>
      </div>

      <div class="footer-col">
        <h4>Resources</h4>
        <a href="/blog/how-much-does-a-website-cost-malaysia">Website Cost Guide</a>
        <a href="/blog/types-of-business-websites">Types of Websites</a>
        <a href="/blog/perlukah-setiap-bisnes-ada-website">Bisnes Perlukan Website?</a>
        <a href="/blog/ai-dalam-web-development">AI dalam Web Dev</a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <span>© 2026 404found.studio · Malaysia</span>
    <span class="mono-sm">Built with coffee &amp; Astro ⚡</span>
  </div>
</footer>

<style>
  footer {
    background: var(--bg3);
    color: var(--bg);
    border-top: 2px solid var(--ink);
  }

  .footer-top {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 3rem 3rem;
    display: flex;
    gap: 4rem;
    align-items: flex-start;
  }

  .footer-brand {
    flex: 0 0 280px;
  }

  .logo {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--bg);
    display: inline-flex;
    align-items: center;
    margin-bottom: 1rem;
  }

  .logo-404 {
    background: var(--accent);
    color: #fff;
    padding: 1px 5px;
    font-size: 0.78rem;
    font-weight: 700;
    font-family: 'Space Mono', monospace;
  }

  .footer-brand p {
    font-size: 0.85rem;
    line-height: 1.7;
    color: var(--text3);
    margin-bottom: 1.25rem;
  }

  .footer-contact-inline {
    display: flex;
    gap: 0.75rem;
    font-size: 0.8rem;
    font-family: 'Space Mono', monospace;
    color: var(--text3);
    flex-wrap: wrap;
  }

  .footer-contact-inline a {
    color: var(--accent);
    transition: opacity 0.15s;
  }

  .footer-contact-inline a:hover { opacity: 0.75; }

  .footer-cols {
    flex: 1;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .footer-col h4 {
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text3);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(240, 237, 230, 0.1);
  }

  .footer-col a {
    display: block;
    font-size: 0.83rem;
    color: var(--text3);
    margin-bottom: 0.5rem;
    transition: color 0.15s;
  }

  .footer-col a:hover { color: var(--bg); }

  .footer-bottom {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.25rem 3rem;
    border-top: 1px solid rgba(240, 237, 230, 0.08);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.72rem;
    color: var(--text3);
    font-family: 'Space Mono', monospace;
  }

  .mono-sm {
    font-family: 'Space Mono', monospace;
  }

  @media (max-width: 768px) {
    .footer-top {
      flex-direction: column;
      padding: 3rem 1.5rem 2rem;
      gap: 2.5rem;
    }
    .footer-brand { flex: none; }
    .footer-cols { grid-template-columns: 1fr 1fr; }
    .footer-bottom { padding: 1rem 1.5rem; flex-direction: column; gap: 0.5rem; text-align: center; }
  }
</style>
