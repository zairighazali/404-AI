---
// src/pages/404.astro
// Three.js via CDN — zero impact on other pages
import Base from '../layouts/Base.astro';
---

<Base
  title="404 — Sesat ke tu? | 404found.studio"
  description="Korang tak sesat, korang dah jumpa studio yang betul."
>
  <div id="scene-container">
    <canvas id="three-canvas"></canvas>

    <div id="ui-overlay">
      <div id="logo-badge">
        <a href="/">404<span>found</span>.studio</a>
      </div>

      <div id="center-content">
        <div id="glitch-404" aria-hidden="true">
          <span class="g-layer" id="g1">404</span>
          <span class="g-layer" id="g2">404</span>
          <span class="g-main">404</span>
        </div>

        <p id="tagline">
          <span id="typedLine"></span><span class="cursor-blink">_</span>
        </p>

        <p id="sub-text">
          Cari 404 Not Found ke tu?
          Dekat <strong>404found.studio</strong> page macam tu tak wujud.
        </p>

        <div id="actions">
          <a href="/" class="btn-home">&#8592; Jom Balik!</a>
          <a href="/#chat-anchor" class="btn-consult">Bina Website Anda &#8594;</a>
        </div>

        <p id="hint">Drag untuk explore &nbsp;&middot;&nbsp; Scroll untuk zoom</p>
      </div>
    </div>
  </div>
</Base>

<script type="importmap">
{
  "imports": {
    "three": "https://cdn.jsdelivr.net/npm/three@0.169.0/build/three.module.js"
  }
}
</script>

<script type="module">
import * as THREE from 'three';

// ── Renderer ────────────────────────────────────────────────────────────────
const canvas = document.getElementById('three-canvas');
const W = window.innerWidth;
const H = window.innerHeight;

const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.setSize(W, H);
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 1.2;

// ── Scene / Camera ──────────────────────────────────────────────────────────
const scene  = new THREE.Scene();
scene.fog    = new THREE.FogExp2(0x000408, 0.008);

const camera = new THREE.PerspectiveCamera(60, W / H, 0.1, 2000);
camera.position.set(0, 0, 80);

// ── Stars (white) ────────────────────────────────────────────────────────────
function makeStars(count, spread, color, size, opacity) {
  const geo = new THREE.BufferGeometry();
  const pos = new Float32Array(count * 3);
  for (let i = 0; i < count * 3; i++) pos[i] = (Math.random() - 0.5) * spread;
  geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
  return new THREE.Points(geo, new THREE.PointsMaterial({
    color, size, sizeAttenuation: true, transparent: true, opacity,
  }));
}
scene.add(makeStars(6000, 1600, 0xffffff, 0.8,  0.85));
scene.add(makeStars(300,   800, 0x00ff88, 1.2,  0.6));

// ── Asteroid materials ────────────────────────────────────────────────────────
const matGrey = new THREE.MeshStandardMaterial({
  color: 0x888888, roughness: 0.95, metalness: 0.05,
});
const matGreen = new THREE.MeshStandardMaterial({
  color: 0x00ff88, roughness: 0.6, metalness: 0.4,
  emissive: new THREE.Color(0x00ff88), emissiveIntensity: 0.3,
});

// ── Pivot group ───────────────────────────────────────────────────────────────
const pivot = new THREE.Group();
scene.add(pivot);

// ── Asteroids ─────────────────────────────────────────────────────────────────
const asteroids = [];
for (let i = 0; i < 60; i++) {
  const detail = Math.floor(Math.random() * 2);
  const geo    = new THREE.IcosahedronGeometry(Math.random() * 2.5 + 0.5, detail);
  const attr   = geo.attributes.position;

  for (let v = 0; v < attr.count; v++) {
    attr.setXYZ(
      v,
      attr.getX(v) * (1 + (Math.random() - 0.5) * 0.4),
      attr.getY(v) * (1 + (Math.random() - 0.5) * 0.4),
      attr.getZ(v) * (1 + (Math.random() - 0.5) * 0.4),
    );
  }
  attr.needsUpdate = true;
  geo.computeVertexNormals();

  const mesh  = new THREE.Mesh(geo, i < 6 ? matGreen : matGrey);
  const r     = 40 + Math.random() * 100;
  const theta = Math.random() * Math.PI * 2;
  const phi   = (Math.random() - 0.5) * Math.PI;

  mesh.position.set(
    r * Math.cos(theta) * Math.cos(phi),
    r * Math.sin(phi),
    r * Math.sin(theta) * Math.cos(phi),
  );
  mesh.rotation.set(
    Math.random() * Math.PI,
    Math.random() * Math.PI,
    Math.random() * Math.PI,
  );
  mesh.userData = {
    rx: (Math.random() - 0.5) * 0.008,
    ry: (Math.random() - 0.5) * 0.008,
    rz: (Math.random() - 0.5) * 0.008,
    os: (Math.random() - 0.5) * 0.0005,
    or: r,
    oa: theta,
    ot: phi,
  };
  pivot.add(mesh);
  asteroids.push(mesh);
}

// ── Rings ──────────────────────────────────────────────────────────────────────
const ring1 = new THREE.Mesh(
  new THREE.TorusGeometry(30, 0.15, 8, 120),
  new THREE.MeshBasicMaterial({ color: 0x00ff88, transparent: true, opacity: 0.25 }),
);
ring1.rotation.x = Math.PI / 2.5;
pivot.add(ring1);

const ring2 = new THREE.Mesh(
  new THREE.TorusGeometry(45, 0.08, 8, 160),
  new THREE.MeshBasicMaterial({ color: 0x00ff88, transparent: true, opacity: 0.12 }),
);
ring2.rotation.x = Math.PI / 3;
ring2.rotation.z = 0.3;
pivot.add(ring2);

// ── Lights ─────────────────────────────────────────────────────────────────────
scene.add(new THREE.AmbientLight(0xffffff, 0.3));

const sun = new THREE.DirectionalLight(0xffeedd, 2.5);
sun.position.set(100, 60, 40);
scene.add(sun);

const greenLight = new THREE.PointLight(0x00ff88, 3, 120);
greenLight.position.set(-20, 10, 30);
scene.add(greenLight);

const blueLight = new THREE.PointLight(0x0066ff, 1.5, 100);
blueLight.position.set(40, -30, -20);
scene.add(blueLight);

// ── Interaction ────────────────────────────────────────────────────────────────
const ptr   = { x: 0, y: 0, down: false, lx: 0, ly: 0 };
const rot   = { x: 0, y: 0 };

function pDown(x, y) { ptr.down = true; ptr.lx = x; ptr.ly = y; }
function pMove(x, y) {
  if (!ptr.down) {
    ptr.x = (x / window.innerWidth  - 0.5) * 0.3;
    ptr.y = (y / window.innerHeight - 0.5) * 0.3;
    return;
  }
  rot.y += (x - ptr.lx) * 0.005;
  rot.x += (y - ptr.ly) * 0.005;
  ptr.lx = x; ptr.ly = y;
}

canvas.addEventListener('mousedown',  e => pDown(e.clientX, e.clientY));
window.addEventListener('mouseup',    () => { ptr.down = false; });
window.addEventListener('mousemove',  e => pMove(e.clientX, e.clientY));
canvas.addEventListener('touchstart', e => pDown(e.touches[0].clientX, e.touches[0].clientY), { passive: true });
window.addEventListener('touchend',   () => { ptr.down = false; });
window.addEventListener('touchmove',  e => pMove(e.touches[0].clientX, e.touches[0].clientY), { passive: true });
window.addEventListener('wheel',      e => {
  camera.position.z = Math.max(30, Math.min(150, camera.position.z + e.deltaY * 0.08));
}, { passive: true });

window.addEventListener('resize', () => {
  camera.aspect = window.innerWidth / window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
});

// ── Animate ────────────────────────────────────────────────────────────────────
const clock = new THREE.Clock();

function animate() {
  requestAnimationFrame(animate);
  const t = clock.getElapsedTime();

  asteroids.forEach(a => {
    const d = a.userData;
    a.rotation.x += d.rx;
    a.rotation.y += d.ry;
    a.rotation.z += d.rz;
    d.oa += d.os;
    a.position.set(
      d.or * Math.cos(d.oa) * Math.cos(d.ot),
      d.or * Math.sin(d.ot) + Math.sin(t * 0.3 + d.oa) * 3,
      d.or * Math.sin(d.oa) * Math.cos(d.ot),
    );
  });

  pivot.rotation.y += (rot.y - pivot.rotation.y) * 0.05;
  pivot.rotation.x += (rot.x - pivot.rotation.x) * 0.05;
  rot.y += 0.0008;

  camera.position.x += (ptr.x * 15 - camera.position.x) * 0.03;
  camera.position.y += (-ptr.y * 8  - camera.position.y) * 0.03;
  camera.lookAt(scene.position);

  greenLight.intensity = 2.5 + Math.sin(t * 1.5) * 0.8;

  renderer.render(scene, camera);
}

animate();
</script>

<script>
  // Typing animation
  const lines = [
    'Sesat ke tu?',
    'But we found you.',
    'Kami sentiasa ada.',
    '404 is not in our vocabulary.',
  ];
  const el = document.getElementById('typedLine');
  if (el) {
    let li = 0, ci = 0, del = false;
    (function tick() {
      const cur = lines[li];
      if (!del) {
        el.textContent = cur.slice(0, ++ci);
        if (ci === cur.length) { del = true; setTimeout(tick, 2200); return; }
      } else {
        el.textContent = cur.slice(0, --ci);
        if (ci === 0) { del = false; li = (li + 1) % lines.length; }
      }
      setTimeout(tick, del ? 38 : 75);
    })();
  }
</script>

<style is:global>
  html, body {
    margin: 0; padding: 0;
    background: #000408;
    overflow: hidden;
    height: 100%; width: 100%;
  }

  #scene-container {
    position: fixed;
    inset: 0;
  }

  #three-canvas {
    position: absolute;
    inset: 0;
    width: 100% !important;
    height: 100% !important;
    display: block;
    cursor: grab;
  }
  #three-canvas:active { cursor: grabbing; }

  /* Overlay */
  #ui-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 10;
    padding:
      env(safe-area-inset-top,    0px)
      env(safe-area-inset-right,  0px)
      env(safe-area-inset-bottom, 0px)
      env(safe-area-inset-left,   0px);
    box-sizing: border-box;
  }

  /* Logo */
  #logo-badge {
    position: absolute;
    top:  max(1.25rem, env(safe-area-inset-top,  1.25rem));
    left: max(1.25rem, env(safe-area-inset-left, 1.25rem));
    pointer-events: all;
    z-index: 20;
  }
  #logo-badge a {
    font-family: 'Space Mono', monospace;
    font-size: clamp(0.75rem, 3vw, 1rem);
    color: #00ff88;
    text-decoration: none;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }
  #logo-badge a span { color: rgba(255,255,255,0.4); }

  /* Center block */
  #center-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    width: 100%;
    max-width: 600px;
    padding: 5rem 1.5rem 1.5rem;
    box-sizing: border-box;
    pointer-events: none;
    max-height: 100vh;
    overflow: hidden;
    animation: contentIn 0.9s ease both;
  }
  @keyframes contentIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Glitch 404 */
  #glitch-404 {
    position: relative;
    display: inline-block;
    margin-bottom: clamp(0.25rem, 2vh, 1rem);
    line-height: 1;
  }
  .g-layer, .g-main {
    font-family: 'Space Mono', monospace;
    font-size: clamp(4rem, 18vw, 13rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    display: block;
  }
  .g-main {
    background: linear-gradient(135deg, #ffffff 0%, #00ff88 60%, #00cc6a 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 40px rgba(0,255,136,0.5));
  }
  .g-layer {
    position: absolute;
    top: 0; left: 0;
    -webkit-text-fill-color: transparent;
  }
  #g1 {
    background: linear-gradient(135deg, #00ff88, transparent);
    -webkit-background-clip: text; background-clip: text;
    animation: glitch1 4s infinite; opacity: 0.6;
  }
  #g2 {
    background: linear-gradient(135deg, #0066ff, transparent);
    -webkit-background-clip: text; background-clip: text;
    animation: glitch2 4s infinite; opacity: 0.4;
  }
  @keyframes glitch1 {
    0%,90%,100% { transform: translate(0,0);       clip-path: none; }
    92%          { transform: translate(-3px, 2px); clip-path: inset(20% 0 60% 0); }
    94%          { transform: translate( 3px,-1px); clip-path: inset(50% 0 20% 0); }
    96%          { transform: translate(0,0);       clip-path: none; }
  }
  @keyframes glitch2 {
    0%,88%,100% { transform: translate(0,0);       clip-path: none; }
    90%          { transform: translate( 3px,-2px); clip-path: inset(10% 0 70% 0); }
    92%          { transform: translate(-3px, 1px); clip-path: inset(60% 0 10% 0); }
    94%          { transform: translate(0,0);       clip-path: none; }
  }

  /* Tagline */
  #tagline {
    font-family: 'Space Mono', monospace;
    font-size: clamp(0.6rem, 2.5vw, 0.95rem);
    color: #00ff88;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 clamp(0.5rem, 2vh, 1.25rem);
    min-height: 1.4em;
  }
  .cursor-blink { animation: blink 1s infinite; color: #00ff88; }
  @keyframes blink { 0%,49%{opacity:1} 50%,100%{opacity:0} }

  /* Sub text */
  #sub-text {
    font-family: 'Syne', sans-serif;
    font-size: clamp(0.78rem, 2.2vw, 1rem);
    color: rgba(255,255,255,0.5);
    line-height: 1.7;
    margin: 0 0 clamp(1rem, 3vh, 2.5rem);
    max-width: 420px;
    padding: 0 0.5rem;
  }
  #sub-text strong { color: #00ff88; font-weight: 700; }

  /* Buttons */
  #actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    pointer-events: all;
    width: 100%;
    padding: 0 0.5rem;
    box-sizing: border-box;
    margin-bottom: clamp(0.75rem, 2vh, 1.5rem);
  }
  .btn-home, .btn-consult {
    padding: clamp(0.6rem, 2vw, 0.875rem) clamp(1rem, 4vw, 2rem);
    border-radius: 8px;
    font-family: 'Syne', sans-serif;
    font-size: clamp(0.78rem, 2vw, 0.9rem);
    font-weight: 700;
    text-decoration: none;
    transition: all 0.25s;
    display: inline-block;
    white-space: nowrap;
  }
  .btn-home {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    backdrop-filter: blur(10px);
  }
  .btn-home:hover { background: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.4); transform: translateY(-2px); }
  .btn-consult { background: #00ff88; border: 1px solid #00ff88; color: #000; }
  .btn-consult:hover { background: #00cc6a; border-color: #00cc6a; transform: translateY(-2px); box-shadow: 0 8px 30px rgba(0,255,136,0.35); }

  /* Hint */
  #hint {
    font-family: 'Space Mono', monospace;
    font-size: clamp(0.55rem, 1.5vw, 0.68rem);
    color: rgba(255,255,255,0.2);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
    margin: 0;
    animation: fadeHint 2s ease 1.5s both;
  }
  @keyframes fadeHint {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Short landscape screens */
  @media (max-height: 600px) {
    #sub-text { display: none; }
    #hint     { display: none; }
    #glitch-404 { margin-bottom: 0.25rem; }
    #tagline    { margin-bottom: 0.5rem; }
    #actions    { margin-bottom: 0.5rem; }
  }

  /* Very small phones */
  @media (max-width: 360px) {
    #actions { flex-direction: column; align-items: center; }
    .btn-home, .btn-consult { width: 100%; text-align: center; }
  }
</style>