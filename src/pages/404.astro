---
// src/pages/404.astro
// Three.js diload via CDN — HANYA pada page ini sahaja.
// Zero impact pada Pagespeed score page lain.
import Base from '../layouts/Base.astro';
---

<Base
  title="404 — Halaman Ini Tidak Wujud | 404found.studio"
  description="Halaman yang anda cari tidak wujud. Tapi anda dah jumpa studio yang betul."
>
  <!-- TIADA Navbar/Footer — page ini standalone sepenuhnya -->
  <div id="scene-container">
    <canvas id="three-canvas"></canvas>

    <div id="ui-overlay">
      <div id="logo-badge">
        <a href="/">404<span>found</span>.studio</a>
      </div>

      <div id="center-content">
        <div id="glitch-404" aria-hidden="true">
          <span class="g-layer" id="g1">404</span>
          <span class="g-layer" id="g2">404</span>
          <span class="g-main">404</span>
        </div>

        <p id="tagline">
          <span class="typed-text" id="typedLine"></span><span class="cursor-blink">_</span>
        </p>

        <p id="sub-text">
          Nak cari 404 Not Found ke? <br>
          Dekat <strong>404found.studio</strong> page macam ni tak wujud.
        </p>

        <div id="actions">
          <a href="/" class="btn-home">← Jom Balik!</a>
          <a href="/#chat-anchor" class="btn-consult">Bina Website Anda →</a>
        </div>
      </div>

      <div id="hint">
        <span>Drag untuk explore · Scroll untuk zoom</span>
      </div>
    </div>
  </div>
</Base>

<!-- Three.js via CDN — hanya diload pada page ini -->
<script type="importmap">
{
  "imports": {
    "three": "https://cdn.jsdelivr.net/npm/three@0.169.0/build/three.module.js",
    "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.169.0/examples/jsm/"
  }
}
</script>

<script type="module">
import * as THREE from 'three';

// ── Canvas setup ──────────────────────────────────────────────────────────
const canvas    = document.getElementById('three-canvas');
const renderer  = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 1.2;

const scene  = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 2000);
camera.position.set(0, 0, 80);

// ── Fog untuk depth ───────────────────────────────────────────────────────
scene.fog = new THREE.FogExp2(0x000408, 0.008);

// ── Stars background ──────────────────────────────────────────────────────
{
  const starGeo = new THREE.BufferGeometry();
  const count   = 6000;
  const pos     = new Float32Array(count * 3);
  const sizes   = new Float32Array(count);

  for (let i = 0; i < count; i++) {
    pos[i * 3]     = (Math.random() - 0.5) * 1600;
    pos[i * 3 + 1] = (Math.random() - 0.5) * 1600;
    pos[i * 3 + 2] = (Math.random() - 0.5) * 1600;
    sizes[i]       = Math.random() * 2.5 + 0.5;
  }

  starGeo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
  starGeo.setAttribute('size',     new THREE.BufferAttribute(sizes, 1));

  const starMat = new THREE.PointsMaterial({
    color:       0xffffff,
    sizeAttenuation: true,
    size:        0.8,
    transparent: true,
    opacity:     0.85,
  });

  scene.add(new THREE.Points(starGeo, starMat));
}

// ── Green accent stars ────────────────────────────────────────────────────
{
  const geo   = new THREE.BufferGeometry();
  const count = 300;
  const pos   = new Float32Array(count * 3);
  for (let i = 0; i < count; i++) {
    pos[i * 3]     = (Math.random() - 0.5) * 800;
    pos[i * 3 + 1] = (Math.random() - 0.5) * 800;
    pos[i * 3 + 2] = (Math.random() - 0.5) * 800;
  }
  geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
  scene.add(new THREE.Points(geo, new THREE.PointsMaterial({
    color: 0x00ff88, size: 1.2, sizeAttenuation: true,
    transparent: true, opacity: 0.6,
  })));
}

// ── Asteroids ─────────────────────────────────────────────────────────────
const asteroids = [];
const asteroidMat = new THREE.MeshStandardMaterial({
  color:     0x888888,
  roughness: 0.95,
  metalness: 0.05,
});
const accentMat = new THREE.MeshStandardMaterial({
  color:     0x00ff88,
  roughness: 0.6,
  metalness: 0.4,
  emissive:  new THREE.Color(0x00ff88),
  emissiveIntensity: 0.3,
});

for (let i = 0; i < 60; i++) {
  const isAccent = i < 6;
  const geo = new THREE.IcosahedronGeometry(
    Math.random() * 2.5 + 0.5,
    Math.floor(Math.random() * 2)
  );
  // Perturb vertices untuk rupa asteroid
  const posAttr = geo.attributes.position;
  for (let v = 0; v < posAttr.count; v++) {
    posAttr.setXYZ(
      v,
      posAttr.getX(v) * (1 + (Math.random() - 0.5) * 0.4),
      posAttr.getY(v) * (1 + (Math.random() - 0.5) * 0.4),
      posAttr.getZ(v) * (1 + (Math.random() - 0.5) * 0.4),
    );
  }
  posAttr.needsUpdate = true;
  geo.computeVertexNormals();

  const mesh = new THREE.Mesh(geo, isAccent ? accentMat : asteroidMat);
  const r     = 40 + Math.random() * 100;
  const theta = Math.random() * Math.PI * 2;
  const phi   = (Math.random() - 0.5) * Math.PI;

  mesh.position.set(
    r * Math.cos(theta) * Math.cos(phi),
    r * Math.sin(phi),
    r * Math.sin(theta) * Math.cos(phi),
  );
  mesh.rotation.set(
    Math.random() * Math.PI,
    Math.random() * Math.PI,
    Math.random() * Math.PI,
  );

  mesh.userData = {
    rotSpeed: new THREE.Vector3(
      (Math.random() - 0.5) * 0.008,
      (Math.random() - 0.5) * 0.008,
      (Math.random() - 0.5) * 0.008,
    ),
    orbitSpeed:  (Math.random() - 0.5) * 0.0005,
    orbitRadius: r,
    orbitAngle:  theta,
    orbitTilt:   phi,
  };
  scene.add(mesh);
  asteroids.push(mesh);
}

// ── Glowing ring ──────────────────────────────────────────────────────────
{
  const ring = new THREE.Mesh(
    new THREE.TorusGeometry(30, 0.15, 8, 120),
    new THREE.MeshBasicMaterial({ color: 0x00ff88, transparent: true, opacity: 0.25 })
  );
  ring.rotation.x = Math.PI / 2.5;
  scene.add(ring);

  const ring2 = new THREE.Mesh(
    new THREE.TorusGeometry(45, 0.08, 8, 160),
    new THREE.MeshBasicMaterial({ color: 0x00ff88, transparent: true, opacity: 0.12 })
  );
  ring2.rotation.x = Math.PI / 3;
  ring2.rotation.z = 0.3;
  scene.add(ring2);
}

// ── Lighting ──────────────────────────────────────────────────────────────
scene.add(new THREE.AmbientLight(0xffffff, 0.3));

const sunLight = new THREE.DirectionalLight(0xffeedd, 2.5);
sunLight.position.set(100, 60, 40);
scene.add(sunLight);

const greenLight = new THREE.PointLight(0x00ff88, 3, 120);
greenLight.position.set(-20, 10, 30);
scene.add(greenLight);

const blueLight = new THREE.PointLight(0x0066ff, 1.5, 100);
blueLight.position.set(40, -30, -20);
scene.add(blueLight);

// ── Mouse drag orbit ──────────────────────────────────────────────────────
const mouse    = { x: 0, y: 0, isDragging: false, lastX: 0, lastY: 0 };
const groupRot = { x: 0, y: 0 };
const pivot    = new THREE.Group();
scene.add(pivot);
// Move all objects ke dalam pivot untuk rotate bersama
asteroids.forEach(a => { scene.remove(a); pivot.add(a); });
scene.children
  .filter(c => c.type === 'Mesh' && c.geometry?.type === 'TorusGeometry')
  .forEach(r => { scene.remove(r); pivot.add(r); });

canvas.addEventListener('mousedown', e => {
  mouse.isDragging = true;
  mouse.lastX = e.clientX;
  mouse.lastY = e.clientY;
});
window.addEventListener('mouseup',   () => { mouse.isDragging = false; });
window.addEventListener('mousemove', e => {
  if (!mouse.isDragging) {
    // Subtle parallax bila hover
    mouse.x = (e.clientX / window.innerWidth  - 0.5) * 0.3;
    mouse.y = (e.clientY / window.innerHeight - 0.5) * 0.3;
    return;
  }
  const dx = e.clientX - mouse.lastX;
  const dy = e.clientY - mouse.lastY;
  groupRot.y += dx * 0.005;
  groupRot.x += dy * 0.005;
  mouse.lastX = e.clientX;
  mouse.lastY = e.clientY;
});

// Touch support
canvas.addEventListener('touchstart', e => {
  mouse.isDragging = true;
  mouse.lastX = e.touches[0].clientX;
  mouse.lastY = e.touches[0].clientY;
}, { passive: true });
window.addEventListener('touchend',  () => { mouse.isDragging = false; });
window.addEventListener('touchmove', e => {
  if (!mouse.isDragging) return;
  const dx = e.touches[0].clientX - mouse.lastX;
  const dy = e.touches[0].clientY - mouse.lastY;
  groupRot.y += dx * 0.005;
  groupRot.x += dy * 0.005;
  mouse.lastX = e.touches[0].clientX;
  mouse.lastY = e.touches[0].clientY;
}, { passive: true });

// Scroll zoom
window.addEventListener('wheel', e => {
  camera.position.z = Math.max(30, Math.min(150, camera.position.z + e.deltaY * 0.08));
}, { passive: true });

// ── Resize ────────────────────────────────────────────────────────────────
window.addEventListener('resize', () => {
  camera.aspect = window.innerWidth / window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
});

// ── Animation loop ────────────────────────────────────────────────────────
const clock = new THREE.Clock();

function animate() {
  requestAnimationFrame(animate);
  const t = clock.getElapsedTime();

  // Rotate asteroids on own axis + orbit
  asteroids.forEach(a => {
    a.rotation.x += a.userData.rotSpeed.x;
    a.rotation.y += a.userData.rotSpeed.y;
    a.rotation.z += a.userData.rotSpeed.z;
    a.userData.orbitAngle += a.userData.orbitSpeed;
    const r   = a.userData.orbitRadius;
    const ang = a.userData.orbitAngle;
    const tlt = a.userData.orbitTilt;
    a.position.set(
      r * Math.cos(ang) * Math.cos(tlt),
      r * Math.sin(tlt) + Math.sin(t * 0.3 + ang) * 3,
      r * Math.sin(ang) * Math.cos(tlt),
    );
  });

  // Smooth pivot rotation (drag + auto-slow-spin)
  pivot.rotation.y += (groupRot.y - pivot.rotation.y) * 0.05;
  pivot.rotation.x += (groupRot.x - pivot.rotation.x) * 0.05;
  groupRot.y += 0.0008; // auto-rotate perlahan

  // Parallax camera
  camera.position.x += (mouse.x * 15 - camera.position.x) * 0.03;
  camera.position.y += (-mouse.y * 8  - camera.position.y) * 0.03;
  camera.lookAt(scene.position);

  // Pulse green light
  greenLight.intensity = 2.5 + Math.sin(t * 1.5) * 0.8;

  renderer.render(scene, camera);
}

animate();
</script>

<style is:global>
  /* Reset untuk page ini sahaja */
  body { margin: 0; padding: 0; background: #000408; overflow: hidden; }

  #scene-container {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
  }

  #three-canvas {
    position: absolute;
    inset: 0;
    width: 100% !important;
    height: 100% !important;
    cursor: grab;
  }

  #three-canvas:active { cursor: grabbing; }

  /* ── UI Overlay ── */
  #ui-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 10;
  }

  /* Logo badge */
  #logo-badge {
    position: absolute;
    top: 1.5rem;
    left: 2rem;
    pointer-events: all;
  }

  #logo-badge a {
    font-family: 'Space Mono', monospace;
    font-size: 1rem;
    color: #00ff88;
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  #logo-badge a span { color: rgba(255,255,255,0.4); }

  /* Center content */
  #center-content {
    text-align: center;
    padding: 2rem;
    pointer-events: none;
  }

  /* Glitch 404 */
  #glitch-404 {
    position: relative;
    display: inline-block;
    margin-bottom: 1rem;
  }

  .g-layer, .g-main {
    font-family: 'Space Mono', monospace;
    font-size: clamp(6rem, 20vw, 14rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    display: block;
    color: #fff;
  }

  .g-main {
    background: linear-gradient(135deg, #ffffff 0%, #00ff88 60%, #00cc6a 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 40px rgba(0,255,136,0.5));
  }

  .g-layer {
    position: absolute;
    top: 0; left: 0;
    -webkit-text-fill-color: transparent;
  }

  #g1 {
    background: linear-gradient(135deg, #00ff88, transparent);
    -webkit-background-clip: text;
    background-clip: text;
    animation: glitch1 4s infinite;
    opacity: 0.6;
  }

  #g2 {
    background: linear-gradient(135deg, #0066ff, transparent);
    -webkit-background-clip: text;
    background-clip: text;
    animation: glitch2 4s infinite;
    opacity: 0.4;
  }

  @keyframes glitch1 {
    0%, 90%, 100% { transform: translate(0,0); clip-path: none; }
    92%            { transform: translate(-3px, 2px); clip-path: inset(20% 0 60% 0); }
    94%            { transform: translate(3px, -1px); clip-path: inset(50% 0 20% 0); }
    96%            { transform: translate(0,0); clip-path: none; }
  }

  @keyframes glitch2 {
    0%, 88%, 100% { transform: translate(0,0); clip-path: none; }
    90%            { transform: translate(3px, -2px); clip-path: inset(10% 0 70% 0); }
    92%            { transform: translate(-3px, 1px); clip-path: inset(60% 0 10% 0); }
    94%            { transform: translate(0,0); clip-path: none; }
  }

  /* Tagline typing */
  #tagline {
    font-family: 'Space Mono', monospace;
    font-size: clamp(0.75rem, 2vw, 1rem);
    color: #00ff88;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 0 0 1.25rem;
  }

  .cursor-blink {
    animation: blink 1s infinite;
    color: #00ff88;
  }

  @keyframes blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  /* Sub text */
  #sub-text {
    font-family: 'Syne', sans-serif;
    font-size: clamp(0.85rem, 2vw, 1.05rem);
    color: rgba(255,255,255,0.55);
    line-height: 1.75;
    margin: 0 0 2.5rem;
    max-width: 480px;
  }

  #sub-text strong {
    color: #00ff88;
    font-weight: 700;
  }

  /* Action buttons */
  #actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    pointer-events: all;
  }

  .btn-home, .btn-consult {
    padding: 0.875rem 2rem;
    border-radius: 8px;
    font-family: 'Syne', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.25s;
    display: inline-block;
  }

  .btn-home {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    backdrop-filter: blur(10px);
  }

  .btn-home:hover {
    background: rgba(255,255,255,0.15);
    border-color: rgba(255,255,255,0.4);
    transform: translateY(-2px);
  }

  .btn-consult {
    background: #00ff88;
    border: 1px solid #00ff88;
    color: #000;
  }

  .btn-consult:hover {
    background: #00cc6a;
    border-color: #00cc6a;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0,255,136,0.35);
  }

  /* Hint */
  #hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
    pointer-events: none;
    animation: fadeInUp 2s ease 1s both;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateX(-50%) translateY(10px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  /* Entry animation */
  #center-content {
    animation: fadeInUp 0.8s ease both;
  }

  @media (max-width: 640px) {
    #hint { display: none; }
    #sub-text { display: none; }
    #actions { gap: 0.75rem; }
    .btn-home, .btn-consult { padding: 0.75rem 1.5rem; font-size: 0.85rem; }
  }
</style>

<script>
  // Typing animation untuk tagline
  const lines = [
    'Halaman ini tidak wujud.',
    'But we found our way.',
    'Tapi kami sentiasa ada.',
    '404 ≠ hopeless.',
  ];

  const el      = document.getElementById('typedLine')!;
  let   lineIdx = 0;
  let   charIdx = 0;
  let   deleting = false;

  function type() {
    const current = lines[lineIdx];
    if (!deleting) {
      el.textContent = current.slice(0, ++charIdx);
      if (charIdx === current.length) {
        deleting = true;
        setTimeout(type, 2200); // pause sebelum delete
        return;
      }
    } else {
      el.textContent = current.slice(0, --charIdx);
      if (charIdx === 0) {
        deleting = false;
        lineIdx  = (lineIdx + 1) % lines.length;
      }
    }
    setTimeout(type, deleting ? 40 : 80);
  }

  setTimeout(type, 800);
</script>
