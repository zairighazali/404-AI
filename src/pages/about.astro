---
// src/pages/about.astro
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Base title="About — 404found.studio" description="404found.studio is a Malaysian web studio building fast, modern websites. Learn about our philosophy, tech stack, and team.">
  <Navbar />
  <main style="padding-top:5rem;max-width:1000px;margin:0 auto;padding-left:2rem;padding-right:2rem;">
    <div style="padding:4rem 0 3rem;">
      <p class="label">Who we are</p>
      <h1>About 404found.studio</h1>
    </div>

    <div class="about-grid">
      <div class="about-text">
        <p>We’re a small web outfit based in Malaysia. Quiet operation. We build fast, modern websites that do their job, bring business through the door — not just stand there looking handsome.</p>
        <p>The name <strong>"404found"</strong> comes from an old mistake every developer knows. The <em>404 error</em>. Means something’s missing. Not found. Most people stop there. We don’t. Where others hit a wall and walk away, we find the door and walk through it. Over the years we’ve built everything, from simple landing pages for small neighbourhood restaurants to booking systems and online shops handling thousands of customers without breaking a sweat.</p>
        <p>Our rules are simple. A proper website loads in under two seconds. It earns its place on Google. It turns visitors into paying customers. And it stays simple enough that running it doesn’t give you a headache. Everything else? Just noise.</p>
        <p>We work with modern, fast tools, the kind built for speed and precision. Clean frameworks, global infrastructure, and lightweight systems that keep things sharp. No bloated themes. No ancient spaghetti code dragging your business into the mud.</p>
        <blockquote>"A good website shows off. A great one stays quiet, does its job, and makes you money while everyone else is still loading."</blockquote>


        <div class="tech-section">
          <h3>Technologies We Use</h3>
          <div class="tech-stack">
            {['Astro', 'Next.js', 'TailwindCSS', 'TypeScript', 'AWS', 'Workers AI', 'JavaScript', 'Three.js', 'Stripe', 'Sanity CMS', 'React', 'PostgreSQL'].map(t => (
              <span class="tech-pill">{t}</span>
            ))}
          </div>
        </div>
      </div>

      <div class="about-stats">
        <div class="stat-card">
          <div class="stat-num">40+</div>
          <div class="stat-label">Websites delivered</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">&lt;2s</div>
          <div class="stat-label">Average page load</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">100%</div>
          <div class="stat-label">Client satisfaction</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">5★</div>
          <div class="stat-label">Average rating</div>
        </div>

        <div class="contact-card">
          <h3>Get in touch</h3>
          <a href="mailto:mohdzairighazali@yahoo.com">✉️ hello@404found.studio</a>
          <a href="https://wa.me/601155525587" target="_blank" rel="noopener">💬 +601155525587</a>
          <a href="/" class="cta-link">Try AI Consultant →</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .label { font-family: 'Space Mono', monospace; font-size: 0.72rem; color: var(--accent); letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 0.75rem; }
  h1 { font-size: 2.75rem; font-weight: 800; letter-spacing: -0.02em; }
  .about-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 4rem; align-items: start; padding-bottom: 5rem; }
  .about-text p { color: var(--text2); font-size: 0.95rem; line-height: 1.85; margin-bottom: 1.25rem; }
  .about-text strong { color: var(--text); }
  blockquote { border-left: 3px solid var(--accent); padding: 1rem 1.25rem; margin: 1.5rem 0; font-style: italic; font-size: 1rem; color: var(--text); line-height: 1.7; background: var(--bg3); border-radius: 0 8px 8px 0; }
  h3 { font-size: 1rem; font-weight: 700; margin-bottom: 1rem; }
  .tech-section { margin-top: 2rem; }
  .tech-stack { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tech-pill { padding: 0.35rem 0.875rem; background: var(--bg3); border: 1px solid var(--border); border-radius: 20px; font-family: 'Space Mono', monospace; font-size: 0.75rem; color: var(--text2); }
  .about-stats { display: flex; flex-direction: column; gap: 1rem; }
  .stat-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; }
  .stat-num { font-family: 'Space Mono', monospace; font-size: 2.5rem; color: var(--accent); font-weight: 700; }
  .stat-label { font-size: 0.82rem; color: var(--text2); margin-top: 0.25rem; }
  .contact-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem; }
  .contact-card h3 { margin-bottom: 0; }
  .contact-card a { font-size: 0.875rem; color: var(--text2); transition: color 0.2s; }
  .contact-card a:hover { color: var(--accent); }
  .cta-link { color: var(--accent) !important; font-weight: 700; margin-top: 0.5rem; }
  @media (max-width: 720px) { .about-grid { grid-template-columns: 1fr; } }
</style>
