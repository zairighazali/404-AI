---
// src/pages/access.astro
import Base from '../layouts/Base.astro';
---

<Base
  title="Private Access — 404found.studio"
  description="Private client access."
  noindex={true}
>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

  <div class="stage">

    <!-- 1. Welcome text -->
    <div class="welcome-screen" id="welcomeScreen">
      <div class="w-clip">
        <span class="w-welcome" id="wWelcome">WELCOME</span>
      </div>
      <div class="w-clip">
        <span class="w-guest" id="wGuest">Special Guest</span>
      </div>
    </div>

    <!-- 2. Logo (hidden initially, moves to top-left) -->
    <div class="logo-el" id="logoEl">
      <img id="logoSvg" src="/logo.png" alt="404found.studio" />
    </div>

  </div>

  <script is:inline>
    var gsap = window.gsap;

    // ── Initial states ──
    gsap.set('#logoEl',   { opacity: 0, scale: 0.7, xPercent: -50, yPercent: -50, left: '50%', top: '50%' });
    gsap.set('#wWelcome', { y: 70, opacity: 0 });
    gsap.set('#wGuest',   { y: 40, opacity: 0 });

    var tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    tl
      // WELCOME slides up
      .to('#wWelcome', { y: 0, opacity: 1, duration: 0.85 }, 0.2)

      // Special Guest fades up
      .to('#wGuest', { y: 0, opacity: 1, duration: 0.7 }, 0.8)

      // Hold
      .to({}, { duration: 1.5 })

      // Text fades out
      .to('#welcomeScreen', { opacity: 0, duration: 0.5, ease: 'power2.in' })

      // Logo appears at center
      .to('#logoEl', { opacity: 1, scale: 1, duration: 0.7, ease: 'back.out(1.3)' })

      // Hold at center
      .to({}, { duration: 0.6 })

      // Rotate 180° counter-clockwise
      .to('#logoSvg', {
        rotation: -180,
        duration: 1.1,
        ease: 'power2.inOut',
        transformOrigin: '50% 50%',
      })

      // Move to top-left, scale down
      .to('#logoEl', {
        left: '32px',
        top: '28px',
        xPercent: 0,
        yPercent: 0,
        scale: 0.28,
        duration: 1.0,
        ease: 'power2.inOut',
      }, '-=0.2');
  </script>
</Base>

<style>
  :global(body) {
    background: #0A0A0A !important;
    overflow: hidden;
  }

  .stage {
    position: fixed;
    inset: 0;
    background: #0A0A0A;
  }

  /* ── Welcome ── */
  .welcome-screen {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.2rem;
  }

  .w-clip {
    overflow: hidden;
    display: flex;
    justify-content: center;
  }

  .w-welcome {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4.5rem, 18vw, 12rem);
    color: #F0EDE6;
    letter-spacing: 0.06em;
    line-height: 1;
    display: block;
    will-change: transform, opacity;
  }

  .w-guest {
    font-family: 'Space Mono', monospace;
    font-size: clamp(0.65rem, 1.8vw, 0.95rem);
    color: rgba(240, 237, 230, 0.32);
    text-transform: uppercase;
    letter-spacing: 0.4em;
    display: block;
    will-change: transform, opacity;
  }

  /* ── Logo ── */
  .logo-el {
    position: fixed;
    will-change: transform, opacity, left, top;
  }

  #logoSvg {
    width: 200px;
    height: 200px;
    object-fit: contain;
    display: block;
    will-change: transform;
  }
</style>
