  ul li { margin-bottom: 0.5rem; }
  .callout { background: var(--bg3); border-left: 3px solid var(--accent); border-radius: 0 8px 8px 0; padding: 1rem 1.25rem; margin: 1.25rem 0; font-size: 0.9rem; color: var(--text2); line-height: 1.7; }
