---
// src/pages/index.astro
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Chat from '../components/Chat.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="404found.studio — Web Development Malaysia | Bina Website Bisnes"
  description="Kami bina website laju dan berkesan untuk bisnes Malaysia. Landing page dari RM1,500, e-commerce dari RM12,000. AI consultant percuma untuk anggaran kos."
  canonicalURL="https://404found.studio/"
  keywords="web development malaysia, buat website malaysia, website bisnes malaysia, landing page malaysia, e-commerce malaysia, buat website murah"
>
  <Navbar />

  <main>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg-number" aria-hidden="true">404</div>

    <div class="hero-inner">
      <div class="hero-tag">
        <span class="tag-dot"></span>
        <span>Web Studio · Malaysia · Est. 2023</span>
      </div>

      <h1>
        <span class="h1-line">Kami bina</span>
        <span class="h1-line h1-big">WEBSITE</span>
        <span class="h1-line h1-big">YANG</span>
        <span class="h1-line h1-red">BERKESAN.</span>
      </h1>

      <div class="hero-rule"></div>

      <p class="hero-sub">
        Blur nak mula dari mana? AI consultant kami akan tolong plan project anda,
        anggaran kos, dan hubungi terus team kami.
      </p>

      <div class="hero-cta">
        <a href="#chat-anchor" class="btn-primary">Mula Sekarang →</a>
        <a href="/services" class="btn-ghost">Lihat Services</a>
      </div>
    </div>

    <div class="stats-bar">
      <div class="stat-item">
        <span class="stat-num">40+</span>
        <span class="stat-label">Sites Built</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat-item">
        <span class="stat-num">&lt;2s</span>
        <span class="stat-label">Load Time</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat-item">
        <span class="stat-num">100%</span>
        <span class="stat-label">Client Satisfaction</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat-item">
        <span class="stat-num">RM1,500</span>
        <span class="stat-label">From</span>
      </div>
    </div>
  </section>

  <!-- Services Strip -->
  <section class="services-strip">
    <div class="strip-label">
      <h2 class="mono">// what we build</h2>
    </div>
    <div class="services-list">
      <a href="/services" class="service-item">
        <span class="service-num">01</span>
        <div class="service-body">
          <h3>Landing Page</h3>
          <p>1–5 pages, custom design, mobile responsive, basic SEO + contact form.</p>
          <span class="service-price">RM1,500 – RM3,000</span>
          <span class="service-delivery">7–14 hari</span>
        </div>
      </a>
      <a href="/services" class="service-item">
        <span class="service-num">02</span>
        <div class="service-body">
          <h3>Business Website</h3>
          <p>Up to 10 pages + Blog/CMS, on-page SEO, Search Console, 2 rounds revision.</p>
          <span class="service-price">RM3,500 – RM7,000</span>
          <span class="service-delivery">3–5 minggu</span>
        </div>
      </a>
      <a href="/services" class="service-item">
        <span class="service-num">03</span>
        <div class="service-body">
          <h3>E-Commerce</h3>
          <p>Cart, checkout, admin panel, payment gateway (ToyyibPay/Stripe/Billplz).</p>
          <span class="service-price">RM12,000 – RM30,000</span>
          <span class="service-delivery">4–8 minggu</span>
        </div>
      </a>
      <a href="/services" class="service-item">
        <span class="service-num">04</span>
        <div class="service-body">
          <h3>SaaS / Web App</h3>
          <p>Full-stack custom (Next.js + Supabase), auth, roles, dashboard, API integrations.</p>
          <span class="service-price">Bermula dari RM30,000</span>
          <span class="service-delivery">8–16 minggu</span>
        </div>
      </a>
    </div>
  </section>

  <!-- Chat -->
  <Chat />
  </main>

  <Footer />
</Base>

<style>
  /* ─── Hero ───────────────────────────────────────────── */
  .hero {
    min-height: 100vh;
    padding: 60px 0 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
  }

  .hero-bg-number {
    position: absolute;
    right: -0.05em;
    top: 50%;
    transform: translateY(-52%);
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(220px, 35vw, 480px);
    color: var(--border);
    line-height: 1;
    user-select: none;
    pointer-events: none;
    letter-spacing: -0.04em;
  }

  .hero-inner {
    padding: 5rem 3rem 3rem;
    max-width: 960px;
    position: relative;
    z-index: 1;
  }

  .hero-tag {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    color: var(--text2);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 2rem;
  }

  .tag-dot {
    width: 8px;
    height: 8px;
    background: var(--accent);
    border-radius: 0;
    display: inline-block;
    animation: pulse 2.5s infinite;
  }

  h1 {
    display: flex;
    flex-direction: column;
    margin-bottom: 0;
  }

  .h1-line {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 0.95;
    letter-spacing: 0.02em;
    color: var(--text);
  }

  .h1-big {
    font-size: clamp(5rem, 14vw, 12rem);
    line-height: 0.88;
    letter-spacing: -0.01em;
  }

  .h1-red {
    font-size: clamp(5rem, 14vw, 12rem);
    line-height: 0.88;
    letter-spacing: -0.01em;
    color: var(--accent);
  }

  .hero-rule {
    width: 100%;
    height: 3px;
    background: var(--ink);
    margin: 2rem 0;
  }

  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--text2);
    max-width: 520px;
    line-height: 1.65;
    margin-bottom: 2.5rem;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    padding: 0.85rem 2rem;
    background: var(--accent);
    color: #fff;
    font-family: 'Space Mono', monospace;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 2px solid var(--accent);
    transition: all 0.15s;
    display: inline-block;
  }

  .btn-primary:hover {
    background: transparent;
    color: var(--accent);
  }

  .btn-ghost {
    padding: 0.85rem 2rem;
    background: transparent;
    color: var(--text);
    font-family: 'Space Mono', monospace;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 2px solid var(--ink);
    transition: all 0.15s;
    display: inline-block;
  }

  .btn-ghost:hover {
    background: var(--ink);
    color: var(--bg);
  }

  /* ─── Stats bar ──────────────────────────────────────── */
  .stats-bar {
    background: var(--bg3);
    color: var(--bg);
    display: flex;
    align-items: stretch;
    border-top: 2px solid var(--ink);
  }

  .stat-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
    padding: 1.5rem 1rem;
  }

  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.2rem;
    line-height: 1;
    color: var(--accent);
  }

  html.dark .stat-num { color: #E8B820; }

  .stat-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text3);
    opacity: 0.8;
  }

  html.dark .stat-label { color: #A09C98; }

  .stat-sep {
    width: 1px;
    background: rgba(240, 237, 230, 0.1);
    margin: 1rem 0;
  }

  /* ─── Services strip ─────────────────────────────────── */
  .services-strip {
    border-top: 2px solid var(--ink);
    padding: 3rem;
    max-width: 100%;
  }

  .strip-label {
    margin-bottom: 2rem;
  }

  .mono {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    font-weight: 400;
    color: var(--text3);
    letter-spacing: 0.05em;
  }

  .services-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    border: 2px solid var(--ink);
  }

  a.service-item {
    text-decoration: none;
    color: inherit;
  }

  .service-item {
    padding: 1.75rem;
    border-right: 1px solid var(--border2);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: background 0.15s;
  }

  .service-item:last-child { border-right: none; }

  .service-item:hover {
    background: var(--accent);
    color: #fff;
  }

  .service-item:hover .service-num,
  .service-item:hover .service-price,
  .service-item:hover p {
    color: rgba(255,255,255,0.85);
  }

  .service-num {
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    color: var(--text3);
    letter-spacing: 0.1em;
  }

  .service-body h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.6rem;
    letter-spacing: 0.03em;
    line-height: 1;
    margin-bottom: 0.4rem;
  }

  .service-body p {
    font-size: 0.85rem;
    color: var(--text2);
    line-height: 1.55;
  }

  .service-price {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    color: var(--accent);
    margin-top: auto;
  }

  .service-delivery {
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    color: var(--text3);
    letter-spacing: 0.05em;
  }

  .service-item:hover .service-price { color: #fff; }
  .service-item:hover .service-delivery { color: rgba(255,255,255,0.6); }

  @media (max-width: 768px) {
    .hero-inner { padding: 4rem 1.5rem 2rem; }
    .hero-bg-number { opacity: 0.5; }
    .stats-bar { flex-wrap: wrap; }
    .stat-sep { display: none; }
    .stat-item { min-width: 50%; }
    .services-strip { padding: 2rem 1.5rem; }
    .services-list { grid-template-columns: 1fr; }
    .service-item { border-right: none; border-bottom: 1px solid var(--border2); }
    .service-item:last-child { border-bottom: none; }
  }
</style>
