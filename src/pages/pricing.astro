---
// src/pages/pricing.astro
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const tiers = [
  {
    num: '01',
    name: 'Landing Page',
    price: 'RM1,500',
    priceMax: 'RM2,500',
    timeline: '7–14 hari',
    features: [
      '1–5 pages, custom design',
      'Mobile responsive',
      'Basic SEO (meta, OG, sitemap, speed)',
      'Contact form',
      'Google Analytics setup',
    ],
  },
  {
    num: '02',
    name: 'Business Website',
    price: 'RM3,500',
    priceMax: 'RM6,000',
    timeline: '3–5 minggu',
    featured: true,
    features: [
      'Up to 10 pages + Blog/CMS',
      'Keyword research + on-page SEO',
      'Google Search Console setup',
      '2 rounds of revision',
    ],
  },
  {
    num: '03',
    name: 'E-Commerce',
    price: 'RM10,000',
    priceMax: 'RM25,000',
    timeline: '4–8 minggu',
    features: [
      'Product catalog, cart, checkout',
      'Admin panel',
      'ToyyibPay / Stripe / Billplz',
      'Basic inventory + order system',
      'SEO for product pages',
    ],
  },
  {
    num: '04',
    name: 'SaaS / Web App',
    price: 'RM30,000',
    priceMax: 'RM150,000+',
    timeline: '8–16 minggu',
    features: [
      'Next.js + Supabase full-stack',
      'Auth, roles, dashboard, admin panel',
      'API integrations',
      'Staging + production deploy',
      'Scope-dependent timeline',
    ],
  },
];

const addons = [
  { name: 'Copywriting', price: 'RM150 – RM300', unit: 'per page' },
  { name: 'AI Feature', price: 'RM800 – RM5,500', unit: 'one-time' },
  { name: 'Extra Revision', price: 'RM300 – RM500', unit: 'per round' },
];
---

<Base
  title="Pricing — Web Development Malaysia | 404found.studio"
  description="Harga buat website Malaysia: landing page RM1,500–RM2,500, business website RM3,500–RM6,000, e-commerce RM10,000–RM25,000, SaaS/web app dari RM30,000."
  canonicalURL="https://404found.studio/pricing"
  keywords="harga buat website malaysia, kos website malaysia, web development price malaysia, berapa harga website, pakej website malaysia"
>
  <Navbar />

  <main class="main">

    <div class="page-header">
      <span class="mono-label">// transparent pricing</span>
      <h1>PRICING</h1>
      <p class="sub">Semua harga dalam Ringgit Malaysia. Quote exact bergantung pada scope projek anda.</p>
    </div>

    <!-- Pricing grid -->
    <section class="pricing-section">
      <div class="pricing-grid">
        {tiers.map(t => (
          <div class={`price-card ${t.featured ? 'featured' : ''}`}>
            {t.featured && <div class="badge">POPULAR</div>}
            <div class="card-top">
              <span class="card-num">{t.num}</span>
              <h2>{t.name}</h2>
              <div class="card-price">
                <span class="price-from">{t.price}</span>
                <span class="price-sep"> – </span>
                <span class="price-to">{t.priceMax}</span>
              </div>
              <div class="card-timeline">{t.timeline}</div>
            </div>
            <ul class="features">
              {t.features.map(f => (
                <li><span class="check">✓</span>{f}</li>
              ))}
            </ul>
            <a href="/" class="card-cta">Dapat Estimate →</a>
          </div>
        ))}
      </div>
    </section>

    <!-- Add-ons -->
    <section class="addons-section">
      <div class="section-head">
        <span class="mono-label">// add-ons (one-time)</span>
        <h2>ADD-ONS</h2>
      </div>
      <div class="addons-table">
        <div class="addons-header">
          <span>Service</span>
          <span>Harga</span>
          <span>Unit</span>
        </div>
        {addons.map(a => (
          <div class="addons-row">
            <span class="addon-name">{a.name}</span>
            <span class="addon-price">{a.price}</span>
            <span class="addon-unit">{a.unit}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Note -->
    <div class="note-block">
      <span class="note-tag">NOTE</span>
      <p>Harga di atas adalah anggaran. Final quote akan disahkan selepas scoping call atau melalui AI consultant kami. <a href="/">Cuba AI consultant →</a></p>
    </div>

    <!-- Payment terms -->
    <section class="terms-section">
      <div class="section-head">
        <span class="mono-label">// syarat pembayaran</span>
        <h2>PAYMENT TERMS</h2>
      </div>
      <div class="terms-grid">
        <div class="term-item">
          <span class="term-num">50%</span>
          <div>
            <strong>Deposit</strong>
            <p>Bayar sebelum kerja bermula. Ini selamatkan masa anda dan kami.</p>
          </div>
        </div>
        <div class="term-divider"></div>
        <div class="term-item">
          <span class="term-num">50%</span>
          <div>
            <strong>Final payment</strong>
            <p>Bayar selepas website siap dan anda approved. Baru kami deploy.</p>
          </div>
        </div>
      </div>
      <p class="payment-methods">
        <span class="mono-label" style="display:inline;">Accepted:</span>
        &nbsp;Bank transfer (Maybank · CIMB · Bank Islam) · DuitNow · Online payment
      </p>
    </section>

    <!-- CTA -->
    <div class="cta-block">
      <div class="cta-inner">
        <div>
          <h2>READY NAK<br />BUAT WEBSITE?</h2>
          <p>AI consultant kami boleh bagi estimate dalam masa 2 minit.</p>
        </div>
        <div class="cta-btns">
          <a href="/" class="btn-primary">Cuba AI Consultant →</a>
          <a href="https://wa.me/601155525587" class="btn-wa" target="_blank" rel="noopener">WhatsApp Kami</a>
        </div>
      </div>
    </div>

  </main>

  <Footer />
</Base>

<style>
  .main {
    padding-top: 60px;
    max-width: 1100px;
    margin: 0 auto;
    padding-left: 3rem;
    padding-right: 3rem;
  }

  .mono-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    color: var(--text3);
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 0.75rem;
  }

  /* ─── Page header ────────────────────────────────────── */
  .page-header {
    padding: 4rem 0 3rem;
    border-bottom: 3px solid var(--ink);
    margin-bottom: 4rem;
  }

  h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4rem, 10vw, 8rem);
    line-height: 0.9;
    letter-spacing: 0.02em;
    margin-bottom: 1.25rem;
  }

  .sub {
    color: var(--text2);
    font-size: 1rem;
    line-height: 1.75;
    max-width: 520px;
  }

  /* ─── Pricing grid ───────────────────────────────────── */
  .pricing-section { margin-bottom: 5rem; }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 2px solid var(--ink);
  }

  .price-card {
    padding: 2rem 1.5rem;
    border-right: 1px solid var(--border2);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: relative;
  }

  .price-card:last-child { border-right: none; }

  .price-card.featured {
    background: var(--bg2);
    border-right-color: var(--border2);
  }

  .badge {
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: #fff;
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    font-weight: 700;
    padding: 3px 12px;
    letter-spacing: 0.1em;
    white-space: nowrap;
  }

  .card-top { display: flex; flex-direction: column; gap: 0.4rem; }

  .card-num {
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    color: var(--text3);
    letter-spacing: 0.1em;
  }

  .price-card h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.6rem;
    letter-spacing: 0.03em;
    line-height: 1;
    color: var(--text);
  }

  .card-price {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0;
  }

  .price-from {
    font-family: 'Space Mono', monospace;
    font-size: 1rem;
    color: var(--accent);
    font-weight: 700;
  }

  .price-sep {
    font-family: 'Space Mono', monospace;
    font-size: 0.75rem;
    color: var(--text3);
  }

  .price-to {
    font-family: 'Space Mono', monospace;
    font-size: 0.85rem;
    color: var(--text2);
  }

  .card-timeline {
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    color: var(--text3);
    letter-spacing: 0.05em;
  }

  .features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .features li {
    font-size: 0.8rem;
    color: var(--text2);
    line-height: 1.5;
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
  }

  .check {
    color: var(--accent);
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    flex-shrink: 0;
  }

  .card-cta {
    display: block;
    text-align: center;
    padding: 0.625rem;
    border: 2px solid var(--ink);
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    color: var(--text);
    font-weight: 700;
    transition: all 0.15s;
    margin-top: auto;
  }

  .card-cta:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  /* ─── Add-ons table ──────────────────────────────────── */
  .addons-section {
    border-top: 2px solid var(--ink);
    padding-top: 3rem;
    margin-bottom: 3rem;
  }

  .section-head { margin-bottom: 1.5rem; }

  h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3rem;
    letter-spacing: 0.02em;
    line-height: 1;
    color: var(--text);
  }

  .addons-table {
    border: 2px solid var(--ink);
    overflow: hidden;
  }

  .addons-header {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    padding: 0.75rem 1.25rem;
    background: var(--bg3);
    color: var(--bg);
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .addons-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    padding: 1rem 1.25rem;
    border-top: 1px solid var(--border2);
    align-items: center;
    transition: background 0.12s;
  }

  .addons-row:hover { background: var(--bg2); }

  .addon-name {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .addon-price {
    font-family: 'Space Mono', monospace;
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 700;
  }

  .addon-unit {
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ─── Note ───────────────────────────────────────────── */
  .note-block {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--border2);
    margin-bottom: 4rem;
    border-left: 4px solid var(--accent);
  }

  .note-tag {
    font-family: 'Space Mono', monospace;
    font-size: 0.62rem;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding-top: 0.15rem;
    flex-shrink: 0;
  }

  .note-block p {
    font-size: 0.875rem;
    color: var(--text2);
    line-height: 1.7;
  }

  .note-block a {
    color: var(--accent);
    font-weight: 600;
  }

  /* ─── Payment terms ──────────────────────────────────── */
  .terms-section {
    border-top: 2px solid var(--ink);
    padding-top: 3rem;
    margin-bottom: 4rem;
  }

  .terms-grid {
    display: flex;
    align-items: center;
    gap: 3rem;
    padding: 2rem 0;
    border-top: 1px solid var(--border2);
    border-bottom: 1px solid var(--border2);
    margin-bottom: 1.5rem;
  }

  .term-item {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    flex: 1;
  }

  .term-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3rem;
    color: var(--accent);
    line-height: 1;
    flex-shrink: 0;
  }

  .term-item strong {
    display: block;
    font-size: 0.95rem;
    margin-bottom: 0.35rem;
  }

  .term-item p {
    font-size: 0.83rem;
    color: var(--text2);
    line-height: 1.6;
  }

  .term-divider {
    width: 1px;
    height: 60px;
    background: var(--border2);
    flex-shrink: 0;
  }

  .payment-methods {
    font-size: 0.82rem;
    color: var(--text2);
  }

  /* ─── CTA ────────────────────────────────────────────── */
  .cta-block {
    background: var(--bg3);
    color: var(--bg);
    padding: 4rem 3rem;
    margin-bottom: 5rem;
    border: 2px solid var(--ink);
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-block h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3rem;
    line-height: 0.95;
    color: var(--bg);
    margin-bottom: 0.75rem;
  }

  .cta-block p { color: var(--text3); font-size: 0.95rem; }

  .cta-btns { display: flex; gap: 1rem; flex-wrap: wrap; }

  .btn-primary {
    padding: 0.875rem 2rem;
    background: var(--accent);
    color: #fff;
    font-family: 'Space Mono', monospace;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 2px solid var(--accent);
    transition: all 0.15s;
    display: inline-block;
    white-space: nowrap;
  }

  .btn-primary:hover { background: transparent; color: var(--accent); }

  .btn-wa {
    padding: 0.875rem 2rem;
    background: #25D366;
    color: #fff;
    font-family: 'Space Mono', monospace;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 2px solid #25D366;
    transition: all 0.15s;
    display: inline-block;
    white-space: nowrap;
  }

  .btn-wa:hover { background: transparent; color: #25D366; }

  @media (max-width: 900px) {
    .main { padding-left: 1.5rem; padding-right: 1.5rem; }
    .pricing-grid { grid-template-columns: 1fr 1fr; }
    .price-card { border-bottom: 1px solid var(--border2); }
    .price-card:nth-child(2n) { border-right: none; }
  }

  @media (max-width: 580px) {
    .pricing-grid { grid-template-columns: 1fr; }
    .price-card { border-right: none; }
    .terms-grid { flex-direction: column; gap: 2rem; }
    .term-divider { width: 60px; height: 1px; }
    .cta-inner { flex-direction: column; align-items: flex-start; }
    .cta-block h2 { font-size: 2.2rem; }
  }
</style>
