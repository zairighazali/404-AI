---
// src/pages/services.astro
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Services — 404found.studio"
  description="Web development services in Malaysia: landing pages, business websites, e-commerce, speed optimisation, and automation. Transparent pricing."
>
  <Navbar />

  <main class="main">
    <div class="page-header">
      <div class="label">What we do</div>
      <h1>Our Services</h1>
      <p class="sub">We build fast, modern websites that help Malaysian businesses grow online — from landing pages to complex custom systems.</p>
    </div>

    <!-- Core services -->
    <section class="services-section">
      <div class="services-grid">
        {[
          { icon: '', name: 'Landing Page', price: 'RM500 – RM1,500', timeline: '3–5 working days', desc: 'High-converting single pages designed to capture leads and showcase your offer. Perfect for campaigns, product launches, and freelancers. Includes a contact form, mobile optimisation, and basic SEO.' },
          { icon: '', name: 'Business Website', price: 'RM1,500 – RM5,500', timeline: '1–2 weeks', desc: 'Multi-page professional website with custom design, service pages, team section, contact forms, and full mobile optimisation. Ideal for SMEs and service businesses.' },
          { icon: '', name: 'E-commerce Website', price: 'RM5,000 – RM20,000', timeline: '2–4 weeks', desc: 'Full online store with product listings, shopping cart, payment gateway integration (FPX, credit card, e-wallet), and order management. Built to convert.' },
          { icon: '', name: 'Custom System', price: 'Quote required', timeline: '4–8 weeks', desc: 'Booking systems, member portals, dashboards, admin panels, and custom web applications built to your exact specifications. Contact us for a scoping call.' },
          { icon: '', name: 'Speed Optimisation', price: 'From RM500', timeline: '3–5 days', desc: 'Audit and optimise your existing site for Core Web Vitals, faster load times, image optimisation, caching, and improved Google rankings.' },
          { icon: '', name: 'Automation', price: 'From RM800', timeline: '1–2 weeks', desc: 'Automate your business workflows — lead capture, follow-up emails, booking confirmations, CRM integrations, and WhatsApp notifications.' },
        ].map(s => (
          <div class="service-card">
            <div class="service-icon">{s.icon}</div>
            <h2>{s.name}</h2>
            <p>{s.desc}</p>
            <div class="service-meta">
              <span class="price">{s.price}</span>
              <span class="timeline">⏱ {s.timeline}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Add-ons -->
    <section class="addons-section">
      <div class="label">Feature add-ons</div>
      <h2>Enhance Your Website</h2>
      <div class="addons-grid">
        {[
          { icon: '', name: 'Booking System', price: '+RM500', desc: 'Allow customers to book appointments or services directly from your website, with email confirmations.' },
          { icon: '', name: 'Online Payment', price: '+RM800', desc: 'Accept FPX, credit card, and e-wallet payments via Stripe or Billplz — fully integrated and secure.' },
          { icon: '', name: 'Blog Setup', price: '+RM300', desc: 'Full blog with categories, tags, RSS feed, and SEO-optimised article pages. Great for content marketing.' },
          { icon: '', name: 'Advanced SEO Setup', price: '+RM400', desc: 'On-page SEO, meta tags, XML sitemap, schema markup, and Google Search Console setup to get found online.' },
        ].map(a => (
          <div class="addon-card">
            <div class="addon-icon">{a.icon}</div>
            <h3>{a.name}</h3>
            <p>{a.desc}</p>
            <div class="addon-price">{a.price}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="label">FAQ</div>
      <h2>Common Questions</h2>
      <div class="faq-list" id="faqList">
        {[
          { q: 'How long does it take to build my website?', a: 'It depends on complexity. Landing pages: 3–5 working days. Business websites: 1–2 weeks. E-commerce: 2–4 weeks. Custom systems vary.' },
          { q: 'Do I need to provide content?', a: 'We recommend providing your own text, photos, and branding where possible. We can help with copywriting and stock photos at an additional cost.' },
          { q: 'Can you help with hosting and domain?', a: 'Yes. We will discuss domains and hosting, of course we will look for the free or cheapest one. The important thing is that it is secured.' },
          { q: 'What payment terms do you use?', a: '50% deposit before work begins, 50% upon completion. We accept bank transfer (Maybank, Bank Islam) and online payment.' },
          { q: 'Will my website work on mobile?', a: 'All our websites are fully responsive and tested on iOS and Android even work on calculator! JK.' },
          { q: 'Do you offer ongoing support?', a: 'Yes. We offer monthly maintenance packages that include updates, backups, and minor changes. Ask us for details.' },
        ].map(faq => (
          <div class="faq-item">
            <button class="faq-q">
              {faq.q}
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-a">{faq.a}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <div class="cta-block">
      <h2>Tak sure macam mana nak start?</h2>
      <p>Tanya je AI Assistant 404found.studio. Tak perlu bayar pun.</p>
      <div class="cta-btns">
        <a href="/" class="btn-primary">Try AI Consultant →</a>
        <a href="https://wa.me/601155525587" class="btn-wa" target="_blank" rel="noopener"> WhatsApp Us</a>
      </div>
    </div>
  </main>

  <Footer />
</Base>

<style>
  .main { padding-top: 5rem; max-width: 1100px; margin: 0 auto; padding-left: 2rem; padding-right: 2rem; }

  .page-header { text-align: center; padding: 4rem 0 3rem; max-width: 640px; margin: 0 auto; }

  .label {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    color: var(--accent);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  h1 { font-size: 2.75rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 1rem; }
  h2 { font-size: 2rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1.5rem; }

  .sub { color: var(--text2); font-size: 1rem; line-height: 1.75; }

  /* Services */
  .services-section { margin-bottom: 5rem; }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    transition: border-color 0.25s, transform 0.25s;
  }

  .service-card:hover { border-color: rgba(0, 255, 136, 0.3); transform: translateY(-2px); }

  .service-icon { font-size: 2rem; margin-bottom: 1rem; }

  .service-card h2 { font-size: 1.1rem; margin-bottom: 0.75rem; }

  .service-card p { font-size: 0.875rem; color: var(--text2); line-height: 1.75; margin-bottom: 1.25rem; }

  .service-meta { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; }

  .price { font-family: 'Space Mono', monospace; font-size: 0.9rem; color: var(--accent); font-weight: 700; }

  .timeline { font-size: 0.8rem; color: var(--text3); }

  /* Add-ons */
  .addons-section { margin-bottom: 5rem; }

  .addons-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.25rem; }

  .addon-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .addon-icon { font-size: 1.5rem; margin-bottom: 0.75rem; }

  .addon-card h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.5rem; }

  .addon-card p { font-size: 0.82rem; color: var(--text2); line-height: 1.65; margin-bottom: 1rem; }

  .addon-price { font-family: 'Space Mono', monospace; font-size: 1rem; color: var(--accent); font-weight: 700; }

  /* FAQ */
  .faq-section { max-width: 720px; margin-bottom: 5rem; }

  .faq-list { display: flex; flex-direction: column; }

  .faq-item { border-bottom: 1px solid var(--border); }

  .faq-q {
    width: 100%;
    background: none;
    border: none;
    text-align: left;
    padding: 1.25rem 0;
    font-family: 'Syne', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .faq-icon {
    color: var(--accent);
    font-family: 'Space Mono', monospace;
    font-size: 1.2rem;
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .faq-icon.open { transform: rotate(45deg); }

  .faq-a {
    font-size: 0.875rem;
    color: var(--text2);
    line-height: 1.75;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
  }

  .faq-a.open { max-height: 200px; padding-bottom: 1.25rem; }

  /* CTA */
  .cta-block {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 3rem;
    text-align: center;
    margin-bottom: 4rem;
  }

  .cta-block h2 { font-size: 1.75rem; margin-bottom: 0.75rem; }

  .cta-block p { color: var(--text2); margin-bottom: 2rem; }

  .cta-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  .btn-primary {
    padding: 0.875rem 2rem;
    border-radius: 8px;
    background: var(--accent);
    color: #000;
    font-weight: 700;
    font-size: 0.95rem;
    transition: all 0.2s;
    display: inline-block;
  }

  .btn-primary:hover { background: var(--accent2); }

  .btn-wa {
    padding: 0.875rem 2rem;
    border-radius: 8px;
    background: #25D366;
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
    transition: all 0.2s;
    display: inline-block;
  }

  .btn-wa:hover { background: #1da851; }
</style>

<script>
  document.querySelectorAll('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling!;
      const icon = btn.querySelector('.faq-icon')!;
      answer.classList.toggle('open');
      icon.classList.toggle('open');
    });
  });
</script>
