---
// src/pages/services.astro
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    num: '01',
    name: 'Landing Page',
    price: 'RM1,500 – RM2,500',
    timeline: '7–14 hari',
    desc: 'High-converting single page untuk product launch, campaign, atau bisnes baru. Direka untuk convert visitors jadi leads.',
    includes: ['1–5 pages, custom design', 'Mobile responsive', 'Basic SEO (meta, OG, sitemap, speed)', 'Contact form + Google Analytics'],
  },
  {
    num: '02',
    name: 'Business Website',
    price: 'RM3,500 – RM6,000',
    timeline: '3–5 minggu',
    desc: 'Website profesional untuk company yang serius. Ada blog/CMS, on-page SEO, dan 2 rounds revision.',
    includes: ['Up to 10 pages + Blog/CMS', 'Keyword research + on-page SEO', 'Google Search Console setup', '2 rounds of revision'],
  },
  {
    num: '03',
    name: 'E-Commerce',
    price: 'RM10,000 – RM25,000',
    timeline: '4–8 minggu',
    desc: 'Online shop lengkap dengan payment gateway Malaysia, admin panel, dan inventory system.',
    includes: ['Product catalog, cart, checkout', 'Admin panel', 'Payment: ToyyibPay / Stripe / Billplz', 'Basic inventory + order system', 'SEO for product pages'],
  },
  {
    num: '04',
    name: 'SaaS / Web App',
    price: 'RM30,000 – RM150,000+',
    timeline: '8–16 minggu',
    desc: 'Custom full-stack application — platform SaaS, sistem dalaman, atau portal client. Scope dependent.',
    includes: ['Next.js + Supabase full-stack', 'Auth, roles, dashboard, admin panel', 'API integrations', 'Staging + production deploy'],
  },
];

const addons = [
  { name: 'Copywriting', price: 'RM150 – RM300', unit: 'per page', desc: 'Professional copy yang SEO-friendly untuk setiap page website anda.' },
  { name: 'AI Feature', price: 'RM800 – RM5,500', unit: 'one-time', desc: 'Chatbot, automation, atau AI integration — seperti AI consultant kami ini.' },
  { name: 'Extra Revision', price: 'RM300 – RM500', unit: 'per round', desc: 'Tambah round revision di luar scope asal projek.' },
];

const faqs = [
  { q: 'Berapa lama website siap?', a: 'Landing page: 7–14 hari. Business website: 3–5 minggu. E-commerce: 4–8 minggu. SaaS/Web App: 8–16 minggu bergantung scope.' },
  { q: 'Apa yang perlu saya sediakan?', a: 'Logo, warna brand, dan content (teks + gambar) kalau ada. Kalau takde, kami boleh bantu dengan copywriting (add-on) dan stock photos.' },
  { q: 'Boleh tak bantu dengan domain dan hosting?', a: 'Boleh. Kami akan recommend domain dan hosting yang sesuai dengan budget — yang paling murah atau percuma kalau boleh, yang penting secure dan laju.' },
  { q: 'Apa syarat pembayaran?', a: '50% deposit sebelum kerja bermula, 50% selepas siap dan approved. Kami accept bank transfer (Maybank, CIMB, Bank Islam) dan online payment.' },
  { q: 'Website akan mobile-friendly ke?', a: 'Semua website kami 100% responsive — tested on iOS, Android, tablet, dan desktop. Mobile-first approach.' },
  { q: 'Ada support lepas website siap?', a: 'Ya. Kami offer monthly maintenance (updates, backup, minor changes). Tanya kami untuk details dan harga.' },
];
---

<Base
  title="Services — Web Development Malaysia | 404found.studio"
  description="Web development services Malaysia: landing page RM1,500, business website RM3,500, e-commerce RM10,000, SaaS/web app dari RM30,000. Custom design, SEO included."
  canonicalURL="https://404found.studio/services"
  keywords="web development services malaysia, harga buat website malaysia, website design malaysia, e-commerce development malaysia, saas development malaysia"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(f => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  }}
>
  <Navbar />

  <main class="main">

    <!-- Page header -->
    <div class="page-header">
      <span class="mono-label">// what we build</span>
      <h1>OUR<br />SERVICES</h1>
      <p class="sub">Kami bina website yang laju, modern, dan berkesan untuk bisnes Malaysia — dari landing page sampai custom web app.</p>
    </div>

    <!-- Services list -->
    <section class="services-section">
      {services.map(s => (
        <div class="service-row">
          <div class="service-row-left">
            <span class="row-num">{s.num}</span>
            <div>
              <h2>{s.name}</h2>
              <p class="row-desc">{s.desc}</p>
            </div>
          </div>
          <div class="service-row-right">
            <div class="row-includes">
              {s.includes.map(item => (
                <div class="include-item">
                  <span class="check">✓</span>
                  <span>{item}</span>
                </div>
              ))}
            </div>
            <div class="row-meta">
              <div>
                <span class="meta-label">Harga</span>
                <span class="meta-price">{s.price}</span>
              </div>
              <div>
                <span class="meta-label">Delivery</span>
                <span class="meta-timeline">{s.timeline}</span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </section>

    <!-- Add-ons -->
    <section class="addons-section">
      <div class="section-head">
        <span class="mono-label">// add-ons (one-time)</span>
        <h2>TAMBAH FEATURES</h2>
      </div>
      <div class="addons-grid">
        {addons.map(a => (
          <div class="addon-card">
            <h3>{a.name}</h3>
            <p>{a.desc}</p>
            <div class="addon-footer">
              <span class="addon-price">{a.price}</span>
              <span class="addon-unit">{a.unit}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="section-head">
        <span class="mono-label">// soalan lazim</span>
        <h2>FAQ</h2>
      </div>
      <div class="faq-list" id="faqList">
        {faqs.map(faq => (
          <div class="faq-item">
            <button class="faq-q">
              {faq.q}
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-a">{faq.a}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <div class="cta-block">
      <div class="cta-inner">
        <div>
          <h2>TAK SURE NAK<br />MULA DARI MANA?</h2>
          <p>Tanya AI consultant kami. Free, tiada obligation.</p>
        </div>
        <div class="cta-btns">
          <a href="/" class="btn-primary">Cuba AI Consultant →</a>
          <a href="https://wa.me/601155525587" class="btn-wa" target="_blank" rel="noopener">WhatsApp Kami</a>
        </div>
      </div>
    </div>

  </main>

  <Footer />
</Base>

<style>
  .main {
    padding-top: 60px;
    max-width: 1100px;
    margin: 0 auto;
    padding-left: 3rem;
    padding-right: 3rem;
  }

  .mono-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    color: var(--text3);
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 0.75rem;
  }

  /* ─── Page header ────────────────────────────────────── */
  .page-header {
    padding: 4rem 0 0;
    border-bottom: 3px solid var(--ink);
    padding-bottom: 3rem;
    margin-bottom: 0;
  }

  h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4rem, 10vw, 8rem);
    line-height: 0.9;
    letter-spacing: 0.02em;
    margin-bottom: 1.25rem;
  }

  .sub {
    color: var(--text2);
    font-size: 1rem;
    line-height: 1.75;
    max-width: 560px;
  }

  /* ─── Services list ──────────────────────────────────── */
  .services-section { margin-bottom: 5rem; }

  .service-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    padding: 3rem 0;
    border-bottom: 1px solid var(--border2);
    align-items: start;
  }

  .service-row-left {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .row-num {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    color: var(--text3);
    letter-spacing: 0.1em;
    padding-top: 0.5rem;
    flex-shrink: 0;
  }

  .service-row-left h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.5rem;
    letter-spacing: 0.02em;
    line-height: 1;
    margin-bottom: 0.75rem;
    color: var(--text);
  }

  .row-desc {
    font-size: 0.9rem;
    color: var(--text2);
    line-height: 1.7;
  }

  .service-row-right { display: flex; flex-direction: column; gap: 1.5rem; }

  .row-includes { display: flex; flex-direction: column; gap: 0.5rem; }

  .include-item {
    display: flex;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: var(--text2);
    align-items: baseline;
  }

  .check {
    color: var(--accent);
    font-family: 'Space Mono', monospace;
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  .row-meta {
    display: flex;
    gap: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border2);
  }

  .meta-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text3);
    display: block;
    margin-bottom: 0.3rem;
  }

  .meta-price {
    font-family: 'Space Mono', monospace;
    font-size: 0.95rem;
    color: var(--accent);
    font-weight: 700;
    display: block;
  }

  .meta-timeline {
    font-family: 'Space Mono', monospace;
    font-size: 0.85rem;
    color: var(--text);
    display: block;
  }

  /* ─── Add-ons ────────────────────────────────────────── */
  .addons-section {
    padding-top: 3rem;
    border-top: 2px solid var(--ink);
    margin-bottom: 5rem;
  }

  .section-head { margin-bottom: 2rem; }

  h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3rem;
    letter-spacing: 0.02em;
    line-height: 1;
    color: var(--text);
  }

  .addons-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 2px solid var(--ink);
  }

  .addon-card {
    padding: 1.75rem;
    border-right: 1px solid var(--border2);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: background 0.15s;
  }

  .addon-card:last-child { border-right: none; }
  .addon-card:hover { background: var(--bg2); }

  .addon-card h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    letter-spacing: 0.03em;
    color: var(--text);
  }

  .addon-card p {
    font-size: 0.83rem;
    color: var(--text2);
    line-height: 1.65;
    flex: 1;
  }

  .addon-footer {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .addon-price {
    font-family: 'Space Mono', monospace;
    font-size: 0.9rem;
    color: var(--accent);
    font-weight: 700;
  }

  .addon-unit {
    font-family: 'Space Mono', monospace;
    font-size: 0.62rem;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ─── FAQ ────────────────────────────────────────────── */
  .faq-section {
    border-top: 2px solid var(--ink);
    padding-top: 3rem;
    margin-bottom: 5rem;
    max-width: 720px;
  }

  .faq-list { display: flex; flex-direction: column; }

  .faq-item { border-bottom: 1px solid var(--border2); }

  .faq-q {
    width: 100%;
    background: none;
    border: none;
    text-align: left;
    padding: 1.25rem 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .faq-icon {
    color: var(--accent);
    font-family: 'Space Mono', monospace;
    font-size: 1.2rem;
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .faq-icon.open { transform: rotate(45deg); }

  .faq-a {
    font-size: 0.875rem;
    color: var(--text2);
    line-height: 1.75;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
  }

  .faq-a.open { max-height: 200px; padding-bottom: 1.25rem; }

  /* ─── CTA ────────────────────────────────────────────── */
  .cta-block {
    background: var(--bg3);
    color: var(--bg);
    padding: 4rem 3rem;
    margin-bottom: 5rem;
    border: 2px solid var(--ink);
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-block h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3rem;
    line-height: 0.95;
    color: var(--bg);
    margin-bottom: 0.75rem;
  }

  .cta-block p { color: var(--text3); font-size: 0.95rem; }

  .cta-btns { display: flex; gap: 1rem; flex-wrap: wrap; }

  .btn-primary {
    padding: 0.875rem 2rem;
    background: var(--accent);
    color: #fff;
    font-family: 'Space Mono', monospace;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 2px solid var(--accent);
    transition: all 0.15s;
    display: inline-block;
    white-space: nowrap;
  }

  .btn-primary:hover { background: transparent; color: var(--accent); }

  .btn-wa {
    padding: 0.875rem 2rem;
    background: #25D366;
    color: #fff;
    font-family: 'Space Mono', monospace;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 2px solid #25D366;
    transition: all 0.15s;
    display: inline-block;
    white-space: nowrap;
  }

  .btn-wa:hover { background: transparent; color: #25D366; }

  @media (max-width: 768px) {
    .main { padding-left: 1.5rem; padding-right: 1.5rem; }
    .service-row { grid-template-columns: 1fr; gap: 1.5rem; }
    .addons-grid { grid-template-columns: 1fr; }
    .addon-card { border-right: none; border-bottom: 1px solid var(--border2); }
    .addon-card:last-child { border-bottom: none; }
    .cta-inner { flex-direction: column; align-items: flex-start; }
    .cta-block h2 { font-size: 2.2rem; }
  }
</style>

<script>
  document.querySelectorAll('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling as HTMLElement;
      const icon = btn.querySelector('.faq-icon') as HTMLElement;
      answer.classList.toggle('open');
      icon.classList.toggle('open');
    });
  });
</script>
