---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Studio — 404FOUNDSTUDIO | Web Development Malaysia"
  description="404FOUNDSTUDIO is a Malaysia-based web studio building fast, modern, and purposeful digital experiences for businesses that want to stand out."
>
  <Navbar />

  <!-- Hero -->
  <section class="studio-hero">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
    <div class="hero-inner">
      <div class="eyebrow">
        <span class="dot"></span>
        Est. 2023 · Kuala Lumpur, Malaysia
      </div>
      <h1>We build websites<br /><span class="accent">that actually work.</span></h1>
      <p class="hero-desc">
        404FOUNDSTUDIO is a boutique web studio specialising in fast, modern digital experiences
        for Malaysian businesses. We combine sharp design, clean code, and AI-powered thinking
        to deliver websites that don't just look good — they perform.
      </p>
    </div>
  </section>

  <!-- Manifesto -->
  <section class="manifesto">
    <div class="manifesto-inner">
      <div class="manifesto-label">
        <span class="dot-sm"></span> Our Manifesto
      </div>
      <blockquote>
        "Most businesses settle for average. We don't.<br />
        Every pixel, every millisecond, every word — intentional."
      </blockquote>
    </div>
  </section>

  <!-- About -->
  <section class="about-section">
    <div class="about-inner">
      <div class="about-text">
        <p class="section-label">Who We Are</p>
        <h2>A studio built for the modern web.</h2>
        <p>
          404FOUNDSTUDIO was born out of frustration with overpriced agencies that deliver slow,
          cookie-cutter websites. We're a lean, focused studio that gives every client the same
          level of attention a large company expects — without the bloated price tag.
        </p>
        <p>
          We work closely with founders, brand owners, and SMEs across Malaysia to build digital
          products that are fast, beautiful, and built to convert.
        </p>
        <p>
          We're not just developers. We're strategic partners who think about your business,
          your users, and your goals before writing a single line of code.
        </p>
      </div>
      <div class="about-cards">
        <div class="info-card">
          <span class="card-label">Founded</span>
          <span class="card-value">2023</span>
        </div>
        <div class="info-card">
          <span class="card-label">Based in</span>
          <span class="card-value">Kuala Lumpur</span>
        </div>
        <div class="info-card">
          <span class="card-label">Projects Delivered</span>
          <span class="card-value accent-text">40+</span>
        </div>
        <div class="info-card">
          <span class="card-label">Avg. Load Time</span>
          <span class="card-value accent-text">&lt; 2s</span>
        </div>
        <div class="info-card">
          <span class="card-label">Satisfaction Rate</span>
          <span class="card-value accent-text">100%</span>
        </div>
        <div class="info-card">
          <span class="card-label">Industries Served</span>
          <span class="card-value">F&B, Retail, SaaS, Services</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="values-section">
    <div class="values-inner">
      <p class="section-label">What Drives Us</p>
      <h2>Built on three principles.</h2>
      <div class="values-grid">
        <div class="value-card">
          <div class="value-num">01</div>
          <h3>Speed is a feature.</h3>
          <p>
            Every 100ms delay costs you conversions. We obsess over performance — from server
            response time to image optimisation. Your site loads fast, or we haven't done our job.
          </p>
        </div>
        <div class="value-card">
          <div class="value-num">02</div>
          <h3>Design with purpose.</h3>
          <p>
            Beautiful is baseline. Great design guides your visitor toward a decision.
            Every layout, colour, and element we choose has a reason behind it — not just aesthetics.
          </p>
        </div>
        <div class="value-card">
          <div class="value-num">03</div>
          <h3>Honest partnership.</h3>
          <p>
            We tell you what you need, not what you want to hear. No hidden fees, no scope creep,
            no jargon. Just clear communication and deliverables that match what was promised.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section class="services-section">
    <div class="services-inner">
      <p class="section-label">What We Do</p>
      <h2>Full-stack studio. End-to-end delivery.</h2>
      <div class="services-list">
        <div class="service-row">
          <div class="service-num">—</div>
          <div class="service-info">
            <h3>Landing Pages & Business Websites</h3>
            <p>High-converting, mobile-first websites built to generate leads and close deals.</p>
          </div>
          <div class="service-tag">From RM 1,500</div>
        </div>
        <div class="service-row">
          <div class="service-num">—</div>
          <div class="service-info">
            <h3>E-Commerce Stores</h3>
            <p>Full online stores with payment integration, inventory management, and SEO built in.</p>
          </div>
          <div class="service-tag">From RM 3,500</div>
        </div>
        <div class="service-row">
          <div class="service-num">—</div>
          <div class="service-info">
            <h3>Custom Web Systems</h3>
            <p>Dashboards, booking platforms, internal tools — built exactly to your workflow.</p>
          </div>
          <div class="service-tag">Custom Quote</div>
        </div>
        <div class="service-row">
          <div class="service-num">—</div>
          <div class="service-info">
            <h3>Website Speed & SEO Optimisation</h3>
            <p>Turn your existing site from a liability into an asset. Lighthouse scores guaranteed.</p>
          </div>
          <div class="service-tag">From RM 800</div>
        </div>
        <div class="service-row">
          <div class="service-num">—</div>
          <div class="service-info">
            <h3>AI Integration & Automation</h3>
            <p>Embed AI chatbots, automate workflows, and build smart features into your product.</p>
          </div>
          <div class="service-tag">Custom Quote</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="process-section">
    <div class="process-inner">
      <p class="section-label">How We Work</p>
      <h2>A process that respects your time.</h2>
      <div class="process-steps">
        <div class="step">
          <div class="step-num">01</div>
          <div class="step-content">
            <h3>Discovery</h3>
            <p>We start with your goals, audience, and business context — not templates. A focused brief before any design begins.</p>
          </div>
        </div>
        <div class="step-line"></div>
        <div class="step">
          <div class="step-num">02</div>
          <div class="step-content">
            <h3>Design & Prototype</h3>
            <p>Clean, purposeful design that reflects your brand. You see and approve before we build.</p>
          </div>
        </div>
        <div class="step-line"></div>
        <div class="step">
          <div class="step-num">03</div>
          <div class="step-content">
            <h3>Build & Optimise</h3>
            <p>Production-grade code. Optimised for speed, SEO, and accessibility from day one — not as an afterthought.</p>
          </div>
        </div>
        <div class="step-line"></div>
        <div class="step">
          <div class="step-num">04</div>
          <div class="step-content">
            <h3>Launch & Support</h3>
            <p>We handle deployment, domain, and DNS. Post-launch support included so you're never left stranded.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="tech-section">
    <div class="tech-inner">
      <p class="section-label">Our Stack</p>
      <h2>Tools built for the modern web.</h2>
      <div class="tech-grid">
        <div class="tech-item">
          <span class="tech-name">Astro</span>
          <span class="tech-desc">Static-first, zero JS by default</span>
        </div>
        <div class="tech-item">
          <span class="tech-name">Next.js</span>
          <span class="tech-desc">Full-stack React apps</span>
        </div>
        <div class="tech-item">
          <span class="tech-name">Tailwind CSS</span>
          <span class="tech-desc">Rapid, consistent styling</span>
        </div>
        <div class="tech-item">
          <span class="tech-name">Cloudflare</span>
          <span class="tech-desc">Edge deployment, globally fast</span>
        </div>
        <div class="tech-item">
          <span class="tech-name">Vercel</span>
          <span class="tech-desc">Serverless at the edge</span>
        </div>
        <div class="tech-item">
          <span class="tech-name">Claude AI</span>
          <span class="tech-desc">Embedded AI for smart features</span>
        </div>
        <div class="tech-item">
          <span class="tech-name">Stripe</span>
          <span class="tech-desc">Payment integration</span>
        </div>
        <div class="tech-item">
          <span class="tech-name">PostgreSQL</span>
          <span class="tech-desc">Reliable relational data</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-inner">
      <div class="cta-glow"></div>
      <p class="section-label">Ready to Build?</p>
      <h2>Let's make something worth<br /><span class="accent">being found.</span></h2>
      <p class="cta-desc">
        Tell us about your project. Our AI consultant will help you plan it,
        estimate the cost, and connect you to our team — in minutes.
      </p>
      <div class="cta-actions">
        <a href="/#chat-anchor" class="btn-primary">Start a Project →</a>
        <a href="/contact" class="btn-outline">Talk to Us</a>
      </div>
      <div class="cta-contact-row">
        <a href="mailto:mohdzairighazali@yahoo.com" class="contact-link">
          <span class="contact-icon">✉</span>
          hello@404found.studio
        </a>
        <span class="contact-sep">·</span>
        <a href="https://wa.me/601155525587" target="_blank" rel="noopener" class="contact-link">
          <span class="contact-icon">↗</span>
          WhatsApp
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
  /* ── Hero ────────────────────────────────────────────────── */
  .studio-hero {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8rem 2rem 5rem;
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.4;
    pointer-events: none;
  }

  .hero-glow {
    position: absolute;
    top: 10%; left: 50%;
    transform: translateX(-50%);
    width: 800px; height: 600px;
    background: radial-gradient(ellipse, rgba(0, 255, 136, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 780px;
  }

  .eyebrow {
    font-family: 'Space Mono', monospace;
    font-size: 0.75rem;
    color: var(--accent);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .dot {
    display: inline-block;
    width: 6px; height: 6px;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  .dot-sm {
    display: inline-block;
    width: 5px; height: 5px;
    background: var(--accent);
    border-radius: 50%;
  }

  .studio-hero h1 {
    font-size: clamp(2.8rem, 6vw, 5.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .accent { color: var(--accent); }

  .hero-desc {
    font-size: 1.05rem;
    color: var(--text2);
    line-height: 1.8;
    max-width: 620px;
    margin: 0 auto;
  }

  /* ── Manifesto ───────────────────────────────────────────── */
  .manifesto {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--bg2);
    padding: 4rem 2rem;
  }

  .manifesto-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .manifesto-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    color: var(--accent);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  blockquote {
    font-size: clamp(1.2rem, 2.5vw, 1.75rem);
    font-weight: 700;
    line-height: 1.5;
    letter-spacing: -0.02em;
    color: var(--text);
    border-left: 3px solid var(--accent);
    padding-left: 1.5rem;
  }

  /* ── About ───────────────────────────────────────────────── */
  .about-section {
    padding: 6rem 2rem;
  }

  .about-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .section-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    color: var(--accent);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .about-text h2 {
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .about-text p {
    font-size: 0.95rem;
    color: var(--text2);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .about-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .info-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    transition: border-color 0.2s;
  }

  .info-card:hover { border-color: rgba(0, 255, 136, 0.3); }

  .card-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.68rem;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .card-value {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }

  .accent-text { color: var(--accent); }

  /* ── Values ──────────────────────────────────────────────── */
  .values-section {
    padding: 6rem 2rem;
    background: var(--bg2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .values-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .values-inner h2 {
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 3rem;
    line-height: 1.2;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .value-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .value-num {
    font-family: 'Space Mono', monospace;
    font-size: 0.8rem;
    color: var(--accent);
    letter-spacing: 0.1em;
  }

  .value-card h3 {
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .value-card p {
    font-size: 0.9rem;
    color: var(--text2);
    line-height: 1.8;
  }

  /* ── Services List ───────────────────────────────────────── */
  .services-section {
    padding: 6rem 2rem;
  }

  .services-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .services-inner h2 {
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 3rem;
    line-height: 1.2;
  }

  .services-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .service-row {
    display: grid;
    grid-template-columns: 2rem 1fr auto;
    gap: 1.5rem;
    align-items: center;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
    transition: all 0.2s;
  }

  .service-row:first-child { border-top: 1px solid var(--border); }

  .service-row:hover { background: var(--bg2); margin: 0 -1.5rem; padding: 1.75rem 1.5rem; }

  .service-num {
    font-family: 'Space Mono', monospace;
    color: var(--accent);
    font-size: 1.2rem;
  }

  .service-info h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
  }

  .service-info p {
    font-size: 0.85rem;
    color: var(--text2);
    line-height: 1.6;
  }

  .service-tag {
    font-family: 'Space Mono', monospace;
    font-size: 0.78rem;
    color: var(--accent);
    background: var(--accent-dim);
    padding: 0.4rem 0.85rem;
    border-radius: 6px;
    white-space: nowrap;
  }

  /* ── Process ─────────────────────────────────────────────── */
  .process-section {
    padding: 6rem 2rem;
    background: var(--bg2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .process-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .process-inner h2 {
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 3rem;
  }

  .process-steps {
    display: flex;
    align-items: flex-start;
    gap: 0;
  }

  .step {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .step-line {
    width: 3rem;
    height: 1px;
    background: var(--border2);
    margin-top: 1.5rem;
    flex-shrink: 0;
  }

  .step-num {
    font-family: 'Space Mono', monospace;
    font-size: 0.78rem;
    color: var(--accent);
    letter-spacing: 0.1em;
  }

  .step-content h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .step-content p {
    font-size: 0.85rem;
    color: var(--text2);
    line-height: 1.7;
  }

  /* ── Tech Stack ──────────────────────────────────────────── */
  .tech-section {
    padding: 6rem 2rem;
  }

  .tech-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .tech-inner h2 {
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 3rem;
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .tech-item {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    transition: border-color 0.2s;
  }

  .tech-item:hover { border-color: rgba(0, 255, 136, 0.35); }

  .tech-name {
    font-weight: 700;
    font-size: 0.95rem;
  }

  .tech-desc {
    font-size: 0.78rem;
    color: var(--text2);
  }

  /* ── CTA ─────────────────────────────────────────────────── */
  .cta-section {
    padding: 6rem 2rem 8rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-glow {
    position: absolute;
    bottom: 0; left: 50%;
    transform: translateX(-50%);
    width: 700px; height: 400px;
    background: radial-gradient(ellipse, rgba(0, 255, 136, 0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .cta-inner h2 {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .cta-desc {
    font-size: 1rem;
    color: var(--text2);
    line-height: 1.8;
    max-width: 520px;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-primary {
    padding: 0.9rem 2.25rem;
    border-radius: 8px;
    background: var(--accent);
    color: #000;
    font-weight: 700;
    font-size: 0.95rem;
    transition: all 0.2s;
    display: inline-block;
  }

  .btn-primary:hover { background: var(--accent2); transform: translateY(-1px); }

  .btn-outline {
    padding: 0.9rem 2.25rem;
    border-radius: 8px;
    background: transparent;
    border: 1px solid var(--border2);
    color: var(--text);
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s;
    display: inline-block;
  }

  .btn-outline:hover { border-color: var(--accent); color: var(--accent); }

  .cta-contact-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.85rem;
    color: var(--text2);
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text2);
    transition: color 0.2s;
  }

  .contact-link:hover { color: var(--accent); }

  .contact-icon { font-size: 0.8rem; }
  .contact-sep { color: var(--text3); }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 900px) {
    .about-inner { grid-template-columns: 1fr; gap: 3rem; }
    .values-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .tech-grid { grid-template-columns: repeat(2, 1fr); }
    .process-steps { flex-direction: column; gap: 1.5rem; }
    .step-line { width: 1px; height: 2rem; margin: 0 0 0 1.5rem; }
  }

  @media (max-width: 640px) {
    .about-cards { grid-template-columns: 1fr; }
    .tech-grid { grid-template-columns: 1fr; }
    .service-row { grid-template-columns: 2rem 1fr; }
    .service-tag { display: none; }
  }
</style>
